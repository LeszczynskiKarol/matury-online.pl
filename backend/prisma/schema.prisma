// ============================================================================
// MATURY-ONLINE.PL — Multi-Subject Exam Prep Platform
// Prisma Schema — PostgreSQL
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USER
// ============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  // null for OAuth users
  name          String?
  avatarUrl     String?
  hideFromLeaderboard Boolean @default(false)
  emailVerified            Boolean   @default(false)
  verificationCode         String?
  verificationCodeExpiresAt DateTime?
  googleId      String?  @unique
  role          UserRole @default(STUDENT)
  reports     QuestionReport[]

  // Subscription
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   SubscriptionStatus @default(FREE)
  subscriptionEnd      DateTime?
  selectedSubjects     UserSubject[]

  // Gamification — global
  totalXp       Int      @default(0)
  aiCreditsRemaining  Int      @default(0)
  aiCreditsResetAt    DateTime?
  globalLevel   Int      @default(1)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime?
  // Gamification — profile
  activeTitle      String   @default("Maturalny Bot")
  showcaseBadgeIds Json     @default("[]")
  // Relations
  subjectProgress  SubjectProgress[]
  answers          Answer[]
  essaySubmissions EssaySubmission[]
  achievements     UserAchievement[]
  reviewCards      ReviewCard[]
  sessions         StudySession[]
  dailyGoals       DailyGoal[]
  notifications    Notification[]
  passwordResets   PasswordReset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questionViewEvents QuestionViewEvent[]

  @@index([email])
  @@index([stripeCustomerId])
}

model UserSubject {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String

  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
}

enum UserRole {
  STUDENT
  ADMIN
}

enum AnswerAction {
  ANSWERED
  SKIPPED
  REVEALED
}


enum SubscriptionStatus {
  FREE
  ACTIVE       // recurring 49 PLN
  ONE_TIME     // single payment 59 PLN (30 days)
  PAST_DUE
  CANCELLED    // cancelled but access until period end
  EXPIRED
}



// ============================================================================
// SUBJECTS & TAXONOMY
// ============================================================================

model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique          // "matematyka", "polski", "biologia"
  name        String                   // "Matematyka"
  description String?
  icon        String?                  // icon name or emoji
  color       String?                  // hex color for UI
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  // Subject-specific taxonomy config
  taxonomyType TaxonomyType @default(TOPIC_TREE)

  topics          Topic[]
  questions       Question[]
  userSubjects    UserSubject[]
  subjectProgress SubjectProgress[]
  studySessions   StudySession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

enum TaxonomyType {
  TOPIC_TREE    // matematyka, biologia, chemia — hierarchical topics
  EPOCH_WORK    // polski — epochs + literary works
}

// Universal topic tree — works for all subjects
// For polski: Topic = epoch, Subtopic = literary work
// For matematyka: Topic = "Algebra", Subtopic = "Równania kwadratowe"
model Topic {
  id          String  @id @default(cuid())
  subject     Subject @relation(fields: [subjectId], references: [id])
  subjectId   String
  parent      Topic?  @relation("TopicTree", fields: [parentId], references: [id])
  parentId    String?
  children    Topic[] @relation("TopicTree")

  slug        String
  name        String              // "Romantyzm" or "Trygonometria"
  description String?
  icon        String?
  sortOrder   Int     @default(0)
  depth       Int     @default(0)  // 0 = root topic, 1 = subtopic, 2 = sub-subtopic

  // For epoch-based subjects (polski)
  dateFrom    String?             // "1822"
  dateTo      String?             // "1863"
  author      String?             // for literary works: "Adam Mickiewicz"

  // Metadata
  questionCount Int @default(0)   // denormalized counter
  isActive      Boolean @default(true)

  questions   Question[]
  reviewCards ReviewCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, slug])
  @@index([subjectId, parentId])
  @@index([subjectId, depth])
}

// ============================================================================
// QUESTIONS & CONTENT
// ============================================================================

model Question {
  id          String       @id @default(cuid())
  subject     Subject      @relation(fields: [subjectId], references: [id])
  subjectId   String
  topic       Topic        @relation(fields: [topicId], references: [id])
  topicId     String
  reports     QuestionReport[]
  viewEvents QuestionViewEvent[]

  type        QuestionType
  difficulty  Int          @default(1) // 1-5
  points      Int          @default(10)

  // Content — JSON-flexible per question type
  // For CLOSED:       { question, options: [{id, text}], correctAnswer: "A" }
  // For MULTI_SELECT: { question, options: [{id, text}], correctAnswers: ["A","C"] }
  // For OPEN:         { question, rubric: string, maxPoints: number, sampleAnswer?: string }
  // For FILL_IN:      { question, blanks: [{id, acceptedAnswers: string[]}] }
  // For ESSAY:        { prompt, criteria: [{name, maxPoints, description}], maxPoints }
  // For MATCHING:     { question, pairs: [{left, right}] }
  // For ORDERING:     { question, items: string[], correctOrder: number[] }
  // For TRUE_FALSE:   { question, statements: [{text, isTrue}] }
  content     Json

  // Explanation shown after answering
  explanation String?

  // Source / attribution
  source      String?      // "CKE 2023", "autorskie"
  isActive    Boolean      @default(true)

  // Stats (denormalized)
  totalAttempts  Int @default(0)
  correctCount   Int @default(0)

  answers     Answer[]
  reviewCards ReviewCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId, topicId])
  @@index([subjectId, type])
  @@index([subjectId, difficulty])
  @@index([type, difficulty])
}

enum QuestionType {
  CLOSED
  MULTI_SELECT
  OPEN
  FILL_IN
  ESSAY
  MATCHING
  ORDERING
  TRUE_FALSE
  ERROR_FIND
  GRAPH_INTERPRET
  TABLE_DATA
  WIAZKA
  PROOF_ORDER
  CLOZE
  LISTENING
  // ── NEW (biologia / genetyka / chemia) ──────────────────────────────────
  DIAGRAM_LABEL       // opis elementów rysunku/schematu (z imageUrl)
  EXPERIMENT_DESIGN   // projekt doświadczenia: hipoteza, próba kontrolna, wniosek
  CROSS_PUNNETT       // krzyżówka genetyczna z tabelą Punnetta + prawdopodobieństwo
  CALCULATION         // obliczenia rachunkowe z jednostką i tolerancją
}

// ============================================================================
// ANSWERS & GRADING
// ============================================================================

model Answer {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  question    Question @relation(fields: [questionId], references: [id])
  questionId  String
  session     StudySession? @relation(fields: [sessionId], references: [id])
  sessionId   String?
  action        AnswerAction @default(ANSWERED)
  aiCreditsUsed Int          @default(0)

  // What the user submitted
  // For CLOSED: "B"
  // For MULTI_SELECT: ["A","C"]
  // For OPEN/ESSAY: "full text answer..."
  // For FILL_IN: {"blank1": "answer", "blank2": "answer"}
  // For MATCHING: {"left1": "right2", ...}
  // For ORDERING: [3, 1, 2, 4]
  response    Json

  // Grading
  isCorrect   Boolean?     // null for AI-graded pending
  score       Float?       // 0.0 - 1.0 normalized
  pointsEarned Int         @default(0)
  xpEarned    Int          @default(0)

  // AI grading details (for OPEN/ESSAY)
  aiGrading   Json?        // { criteria: [{name, score, maxScore, feedback}], overallFeedback }
  gradedAt    DateTime?

  // Time tracking
  timeSpentMs Int?

  createdAt DateTime @default(now())

  @@index([userId, questionId])
  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([sessionId, createdAt])
}

// Separate model for essay submissions — heavier, with revision tracking
model EssaySubmission {
  id          String @id @default(cuid())
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  subjectId   String
  topicId     String
  prompt      String    @db.Text
  content     String    @db.Text

  // AI Evaluation — CKE-aligned criteria
  // { criteria: [{name, score, maxScore, feedback}], overallScore, overallFeedback, strengths, improvements }
  evaluation  Json?
  totalScore  Float?    // 0-100 normalized
  gradedAt    DateTime?

  // Revision tracking
  version     Int       @default(1)
  parentId    String?   // previous version

  wordCount   Int       @default(0)
  timeSpentMs Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, subjectId])
  @@index([userId, createdAt])
}

// ============================================================================
// GAMIFICATION
// ============================================================================

model SubjectProgress {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String

  // Per-subject leveling
  xp          Int @default(0)
  level       Int @default(1)        // 1-5
  questionsAnswered Int @default(0)
  correctAnswers    Int @default(0)

  // Adaptive difficulty — current recommended difficulty
  adaptiveDifficulty Float @default(1.0) // 1.0 - 5.0, smooth

  // Topic mastery — JSON map: { topicId: { mastery: 0.0-1.0, lastPracticed: ISO } }
  topicMastery Json @default("{}")

  updatedAt DateTime @updatedAt

  @@unique([userId, subjectId])
  @@index([userId])
}

// Achievement definitions
model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  category    AchievementCategory
  tier           BadgeTier @default(BRONZE)
  progressTarget Int?
  progressType   String?
  // Unlock condition — evaluated in code
  // "streak_7", "perfect_session", "epoch_complete_romantyzm", "level_5_matematyka"
  conditionType String
  conditionValue Json   // { threshold: 7 } or { subjectSlug: "matematyka", level: 5 }

  xpReward    Int @default(0)
  isActive    Boolean @default(true)
  sortOrder   Int @default(0)

  users UserAchievement[]

  createdAt DateTime @default(now())
}

enum AchievementCategory {
  STREAK          // consecutive days
  MASTERY         // topic/subject mastery
  VOLUME          // number of questions/essays
  PERFECT         // perfect scores
  MILESTONE       // level-ups, first actions
  SPECIAL         // seasonal, events
}

model UserAchievement {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ============================================================================
// SPACED REPETITION (SM-2 variant)
// ============================================================================

model ReviewCard {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  question    Question @relation(fields: [questionId], references: [id])
  questionId  String
  topic       Topic    @relation(fields: [topicId], references: [id])
  topicId     String

  // SM-2 algorithm fields
  easeFactor    Float    @default(2.5)  // >= 1.3
  interval      Int      @default(1)    // days
  repetitions   Int      @default(0)
  nextReviewAt  DateTime @default(now())
  lastReviewAt  DateTime?

  // Quality tracking
  lastQuality   Int?     // 0-5 (SM-2 quality)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
  @@index([userId, topicId])
}

// ============================================================================
// STUDY SESSIONS
// ============================================================================

model StudySession {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String

  type      SessionType
  status    SessionStatus @default(IN_PROGRESS)

  // Config
  topicId       String?      // null = mixed
  difficulty    Int?         // null = adaptive
  questionCount Int          @default(10)

  // Results
  questionsAnswered Int @default(0)
  correctAnswers    Int @default(0)
  totalXpEarned     Int @default(0)
  totalTimeMs       Int @default(0)

  answers Answer[]

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, subjectId])
  @@index([userId, startedAt])
}

enum SessionType {
  PRACTICE        // free practice
  TOPIC_DRILL     // specific topic
  REVIEW          // spaced repetition
  MOCK_EXAM       // timed exam simulation
  ADAPTIVE        // AI-picked questions
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ============================================================================
// DAILY GOALS & STREAKS
// ============================================================================

model DailyGoal {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  date   DateTime @db.Date

  // Goals
  targetQuestions Int @default(10)
  targetXp       Int @default(50)
  targetMinutes  Int @default(15)

  // Actual
  questionsCompleted Int @default(0)
  xpEarned           Int @default(0)
  minutesSpent       Int @default(0)

  isCompleted Boolean @default(false)

  @@unique([userId, date])
  @@index([userId, date])
}

// ============================================================================
// NOTIFICATIONS & ENGAGEMENT
// ============================================================================

model Notification {
  id      String           @id @default(cuid())
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  type    NotificationType
  title   String
  body    String
  data    Json?            // { subjectSlug, achievementId, etc. }
  isRead  Boolean          @default(false)
  sentAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, sentAt])
}

enum NotificationType {
  STREAK_REMINDER
  STREAK_LOST
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
  REVIEW_DUE
  WEEKLY_SUMMARY
  SYSTEM
}

// ============================================================================
// ENGAGEMENT EMAILS (Duolingo-style)
// ============================================================================

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  email     String
  type      String   // "streak_reminder", "weekly_summary", "win_back"
  messageId String?  // SES message ID
  status    EmailStatus @default(SENT)
  sentAt    DateTime @default(now())

  @@index([userId, type])
  @@index([sentAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}


enum EmailStatus {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
}

model ClaudeApiLog {
  id            String   @id @default(cuid())
  caller        String
  model         String
  userId        String?
  questionId    String?
  systemPrompt  String?  @db.Text
  userPrompt    String   @db.Text
  rawResponse   String   @db.Text
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  costUsd       Float    @default(0)
  durationMs    Int      @default(0)
  success       Boolean  @default(true)
  error         String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([caller])
  @@index([createdAt])
  @@index([userId])
}

model QuestionView {
  userId       String
  questionId   String
  viewCount    Int      @default(1)
  lastViewedAt DateTime @default(now())

  @@id([userId, questionId])
  @@index([questionId])
}

// Tracks AI-suggested essay topics per user to ensure variety
model EssayTopicSuggestion {
  id        String   @id @default(cuid())
  userId    String
  subjectId String
  topicId   String?  // optional topic/dział filter
  level     String   // "podstawowy" | "rozszerzony"
  suggestion String  @db.Text // the suggested topic text

  createdAt DateTime @default(now())

  @@index([userId, subjectId])
  @@index([userId, createdAt])
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

model QuestionViewEvent {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  sessionId  String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, createdAt])
  @@index([questionId])
  @@index([createdAt])
}

model QuestionReport {
  id          String       @id @default(cuid())
  question    Question     @relation(fields: [questionId], references: [id])
  questionId  String
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  category    ReportCategory
  description String       @db.Text
  status      ReportStatus @default(NEW)
  adminNote   String?      @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([questionId])
  @@index([status])
  @@index([createdAt])
}

enum ReportCategory {
  WRONG_ANSWER       // błędna odpowiedź
  CONTENT_ERROR      // błąd w treści pytania
  UNCLEAR            // niejasne sformułowanie
  MISSING_CONTENT    // brakujące dane / obraz / kontekst
  DISPLAY_BUG        // problem z wyświetlaniem
  OTHER              // inne
}

enum ReportStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  DISMISSED
}
