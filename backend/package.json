{
  "name": "matury-online-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "tts:generate": "tsx src/jobs/generate-listening-audio.ts",
    "tts:dry-run": "tsx src/jobs/generate-listening-audio.ts --dry-run",
    "listening:generate": "tsx src/jobs/generate-listening-batch.ts",
    "listening:audio": "tsx src/jobs/generate-listening-audio.ts",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "cron:reset-streaks": "tsx src/jobs/cron.ts reset-streaks",
    "cron:streak-reminders": "tsx src/jobs/cron.ts streak-reminders",
    "cron:win-back": "tsx src/jobs/cron.ts win-back",
    "cron:weekly-summary": "tsx src/jobs/cron.ts weekly-summary"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@prisma/client": "^6.2.0",
    "bcrypt": "^5.1.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "google-auth-library": "^9.14.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
