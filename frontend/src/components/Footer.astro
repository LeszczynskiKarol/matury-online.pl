---
import QuestionCounts from './QuestionCounts.astro';
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 py-12 bg-white dark:bg-surface-950">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-5 gap-8 mb-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center">
            <span class="text-white font-display font-bold text-sm">M</span>
          </div>
          <span class="font-display font-bold">Matury Online</span>
        </div>
        <p class="text-sm text-zinc-500 mb-4 max-w-sm">
          Inteligentna platforma do nauki przed maturą 2026. Wszystkie popularne przedmioty, <span data-qcount-min="total">8000+</span> pytań, AI ocena wypracowań, nieograniczone słuchanie angielskiego i niemieckiego generowane na żywo.
        </p>
        <p class="text-xs text-zinc-400">matury-online.pl · polska platforma EdTech</p>
      </div>
      <div>
        <h4 class="font-display font-semibold text-sm mb-4">Przedmioty</h4>
        <ul class="space-y-2 text-sm text-zinc-500">
          <li><a href="/przedmiot/polski" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Polski</a></li>
          <li><a href="/przedmiot/matematyka" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Matematyka</a></li>
          <li><a href="/przedmiot/angielski" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Angielski</a></li>
          <li><a href="/przedmiot/niemiecki" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Niemiecki</a></li>
          <li><a href="/przedmiot/biologia" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Biologia</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-semibold text-sm mb-4">&nbsp;</h4>
        <ul class="space-y-2 text-sm text-zinc-500">
          <li><a href="/przedmiot/chemia" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Chemia</a></li>
          <li><a href="/przedmiot/fizyka" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Fizyka</a></li>
          <li><a href="/przedmiot/historia" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Historia</a></li>
          <li><a href="/przedmiot/geografia" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Geografia</a></li>
          <li><a href="/przedmiot/wos" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">WOS</a></li>
          <li><a href="/przedmiot/informatyka" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Informatyka</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-semibold text-sm mb-4">Prawne</h4>
        <ul class="space-y-2 text-sm text-zinc-500">
          <li><a href="/terms-of-service" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Regulamin</a></li>
          <li><a href="/privacy-policy" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Polityka prywatności</a></li>
          <li>
            <button type="button" onclick="window.openConsentSettings && window.openConsentSettings()" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cookies</button>
          </li>
          <li><a href="/kontakt" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">Kontakt</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-zinc-200 dark:border-zinc-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-zinc-500">© 2026 matury-online.pl · Realizacja: <a href="https://karol-leszczynski.pl" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition">karol-leszczynski.pl</a></p>
      <p class="text-xs text-zinc-400">Matura 2026 · Platforma EdTech · Polski produkt</p>
    </div>
  </div>
</footer>
<QuestionCounts />