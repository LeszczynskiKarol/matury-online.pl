---
import Base from './Base.astro';
import { ThemeToggle } from '../components/ui/ThemeToggle';

interface Props {
  title: string;
  noindex?: boolean;   
}

const { title, noindex } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Base title={`${title} — Matury Online`} noindex={true}>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden lg:flex lg:flex-col lg:w-64 border-r border-zinc-200 dark:border-zinc-800 bg-white dark:bg-surface-900">
      <!-- Logo -->
      <div class="flex items-center justify-between px-6 py-5 border-b border-zinc-200 dark:border-zinc-800">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center">
            <span class="text-white font-display font-bold text-sm">M</span>
          </div>
          <span class="font-display font-bold text-lg">Matury Online</span>
        </div>
        <ThemeToggle client:load />
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <a href="/dashboard" class:list={["nav-link", { active: currentPath === '/dashboard' }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Dashboard
        </a>

        <div class="pt-4 pb-2 px-4">
          <span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Nauka</span>
        </div>

        <a href="/dashboard/sesja" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/sesja') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          Nowa sesja
        </a>
        <a href="/dashboard/historia" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/historia') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Historia sesji
        </a>
        {/*<a href="/dashboard/powtorki" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/powtorki') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Powtórki
        </a> */}
        <a href="/dashboard/wypracowania" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/wypracowania') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Wypracowania
        </a>
        <a href="/dashboard/sluchanie" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/sluchanie') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg>
          Słuchanie
        </a>
        <div class="pt-4 pb-2 px-4">
          <span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Przedmioty</span>
        </div>

        <div id="sidebar-subjects"></div>

        <div class="pt-4 pb-2 px-4">
          <span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Profil</span>
        </div>

        <a href="/dashboard/osiagniecia" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/osiagniecia') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          Odznaki
        </a>
        <a href="/dashboard/statystyki" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/statystyki') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Statystyki
        </a>
        <a href="/dashboard/ranking" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/ranking') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          Ranking
        </a>
        <a href="/dashboard/subskrypcja" class:list={["nav-link", { active: currentPath.startsWith('/dashboard/subskrypcja') }]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          Subskrypcja
        </a>

        <!-- Admin section — hidden by default, shown via JS for ADMIN role -->
        <div id="admin-nav-section" class="hidden">
          <div class="pt-4 pb-2 px-4">
            <span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Admin</span>
          </div>
          <a href="/admin" class:list={["nav-link", { active: currentPath.startsWith('/admin') }]}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Panel admina
          </a>
        </div>
      </nav>

      <!-- User + Logout + Cookies -->
      <div class="border-t border-zinc-200 dark:border-zinc-800 px-4 py-3 space-y-1">
        <button id="sidebar-user" type="button" class="w-full text-left rounded-xl px-2 py-2 hover:bg-zinc-100 dark:hover:bg-surface-800 transition-colors cursor-pointer" title="Zmień hasło"></button>
        <button id="logout-btn" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Wyloguj się
        </button>
        <div class="flex items-center gap-2 px-2">
          <button id="cookies-btn" type="button" class="flex-1 flex items-center justify-center gap-2 py-2 rounded-xl text-xs font-medium text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-surface-800 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            Cookies
          </button>
          <a href="/dashboard/kontakt" class="flex-1 flex items-center justify-center gap-2 py-2 rounded-xl text-xs font-medium text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-surface-800 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Kontakt
          </a>
        </div>
      </div>
    </aside>
<!-- Mobile drawer overlay -->
    <div id="mobile-overlay" class="fixed inset-0 z-50 hidden">
      <div id="mobile-overlay-bg" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
      <aside class="absolute left-0 top-0 h-full w-72 bg-white dark:bg-surface-900 border-r border-zinc-200 dark:border-zinc-800 flex flex-col overflow-y-auto">
        <div class="flex items-center justify-between px-6 py-5 border-b border-zinc-200 dark:border-zinc-800">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center">
              <span class="text-white font-display font-bold text-sm">M</span>
            </div>
            <span class="font-display font-bold text-lg">Matury Online</span>
          </div>
          <button id="mobile-close-btn" class="p-2 rounded-xl hover:bg-zinc-100 dark:hover:bg-surface-800">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1">
          <a href="/dashboard" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Dashboard
          </a>
          <div class="pt-4 pb-2 px-4"><span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Nauka</span></div>
          <a href="/dashboard/sesja" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            Nowa sesja
          </a>
          <a href="/dashboard/historia" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Historia sesji
          </a>
          <a href="/dashboard/wypracowania" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Wypracowania
          </a>
          <div class="pt-4 pb-2 px-4"><span class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Profil</span></div>
          <a href="/dashboard/osiagniecia" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            Odznaki
          </a>
          <a href="/dashboard/statystyki" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Statystyki
          </a>
          <a href="/dashboard/ranking" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            Ranking
          </a>
          <a href="/dashboard/subskrypcja" class="nav-link">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            Subskrypcja
          </a>
        </nav>
        <div class="border-t border-zinc-200 dark:border-zinc-800 px-4 py-3">
          <button id="mobile-logout-btn" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Wyloguj się
          </button>
        </div>
      </aside>
    </div>

    
    <!-- Main content -->
    <main class="flex-1 min-w-0">
      <!-- Top bar (mobile) -->
      <header class="lg:hidden sticky top-0 z-40 flex items-center justify-between px-4 py-3 border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-surface-900/80 backdrop-blur-xl">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center">
            <span class="text-white font-display font-bold text-xs">M</span>
          </div>
          <span class="font-display font-bold">Matury Online</span>
        </div>
        <div class="flex items-center gap-2">
          <ThemeToggle client:load />
          <button id="mobile-menu-btn" class="p-2 rounded-xl hover:bg-zinc-100 dark:hover:bg-surface-800">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </header>

      <!-- Page content -->
      <div class="p-4 md:p-8 max-w-7xl mx-auto">
        <slot />
      </div>
    </main>
  </div>

<!-- Gamification popups portal -->
  <div id="gamification-popups"><script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import { GamificationToasts } from '../components/GamificationToasts';
  const el = document.getElementById('gamification-popups');
  if (el) createRoot(el).render(createElement(GamificationToasts));
</script></div>

  <!-- Profile Settings Modal -->
  <div id="profile-modal" class="fixed inset-0 z-[100] hidden">
    <div id="profile-modal-bg" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="relative w-full max-w-lg bg-white dark:bg-surface-900 rounded-3xl border border-zinc-200 dark:border-zinc-800 shadow-xl overflow-hidden">

        <button id="profile-modal-close" type="button" class="absolute top-4 right-4 z-10 p-2 rounded-xl hover:bg-zinc-100 dark:hover:bg-surface-800 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <div class="p-6">
          <!-- Avatar + User Info row -->
          <div class="flex items-center gap-5 mb-6">
            <!-- Avatar with upload -->
            <div class="relative group flex-shrink-0">
              <div id="avatar-preview" class="w-20 h-20 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-600 dark:text-brand-400 text-2xl font-display font-bold overflow-hidden ring-2 ring-zinc-200 dark:ring-zinc-700">
              </div>
              <label class="absolute inset-0 rounded-full cursor-pointer flex items-center justify-center bg-black/0 group-hover:bg-black/40 transition-colors">
                <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <input id="avatar-input" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
              </label>
              <div id="avatar-spinner" class="hidden absolute inset-0 rounded-full bg-black/50 flex items-center justify-center">
                <svg class="w-6 h-6 text-white animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
              </div>
            </div>

            <!-- Name + email -->
            <div class="flex-1 min-w-0">
              <p id="modal-user-name" class="font-display font-bold text-lg truncate"></p>
              <p id="modal-user-email" class="text-sm text-zinc-500 truncate"></p>
              <button id="avatar-delete-btn" type="button" class="hidden mt-1 text-[11px] text-red-400 hover:text-red-500 font-medium transition-colors">
                Usuń zdjęcie
              </button>
            </div>
          </div>

          <div id="avatar-alert" class="hidden mb-4 px-4 py-3 rounded-2xl text-sm font-medium"></div>

          <!-- Divider -->
          <div class="border-t border-zinc-200 dark:border-zinc-800 mb-4"></div>

          <!-- Password section — collapsible -->
          <button id="pw-toggle" type="button" class="w-full flex items-center justify-between py-2 text-sm font-medium text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
              Zmień hasło
            </span>
            <svg id="pw-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <div id="pw-section" class="hidden mt-3 space-y-3">
            <div id="pw-alert" class="hidden px-4 py-3 rounded-2xl text-sm font-medium"></div>
            <div id="pw-current-wrap">
              <label class="block text-xs font-medium text-zinc-500 mb-1">Obecne hasło</label>
              <input id="pw-current" type="password" class="input !py-2.5 !text-sm" placeholder="••••••••" autocomplete="current-password" />
            </div>
            <div>
              <label class="block text-xs font-medium text-zinc-500 mb-1">Nowe hasło</label>
              <input id="pw-new" type="password" class="input !py-2.5 !text-sm" placeholder="Min. 8 znaków, wielka, cyfra, specjalny" autocomplete="new-password" />
            </div>
            <div>
              <label class="block text-xs font-medium text-zinc-500 mb-1">Powtórz nowe hasło</label>
              <input id="pw-confirm" type="password" class="input !py-2.5 !text-sm" placeholder="••••••••" autocomplete="new-password" />
            </div>
            <button id="pw-submit" type="button" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-2xl text-sm font-semibold bg-zinc-100 dark:bg-surface-800 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-surface-700 transition-colors">
              <span id="pw-submit-text">Zapisz nowe hasło</span>
              <svg id="pw-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (() => {
      // ── Elements ─────────────────────────────────────────────────────────
      const modal = document.getElementById('profile-modal');
      const modalBg = document.getElementById('profile-modal-bg');
      const closeBtn = document.getElementById('profile-modal-close');
      const avatarPreview = document.getElementById('avatar-preview');
      const avatarInput = document.getElementById('avatar-input') as HTMLInputElement | null;
      const avatarSpinner = document.getElementById('avatar-spinner');
      const avatarDeleteBtn = document.getElementById('avatar-delete-btn');
      const avatarAlert = document.getElementById('avatar-alert');
      const modalName = document.getElementById('modal-user-name');
      const modalEmail = document.getElementById('modal-user-email');

      const pwToggle = document.getElementById('pw-toggle');
      const pwChevron = document.getElementById('pw-chevron');
      const pwSection = document.getElementById('pw-section');
      const pwAlert = document.getElementById('pw-alert');
      const pwCurrentWrap = document.getElementById('pw-current-wrap');
      const pwCurrent = document.getElementById('pw-current') as HTMLInputElement | null;
      const pwNew = document.getElementById('pw-new') as HTMLInputElement | null;
      const pwConfirm = document.getElementById('pw-confirm') as HTMLInputElement | null;
      const pwSubmit = document.getElementById('pw-submit') as HTMLButtonElement | null;
      const pwSubmitText = document.getElementById('pw-submit-text');
      const pwSpinner = document.getElementById('pw-spinner');

      let cachedUser: any = null;
      let isGoogleOnly = false;

      // ── Helpers ──────────────────────────────────────────────────────────
      function showAlertEl(el: HTMLElement | null, msg: string, type: 'error' | 'success') {
        if (!el) return;
        el.textContent = msg;
        el.className = `mb-4 px-4 py-3 rounded-2xl text-sm font-medium ${
          type === 'error'
            ? 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400'
            : 'bg-brand-50 dark:bg-brand-900/20 text-brand-700 dark:text-brand-400'
        }`;
      }

      function renderAvatar(user: any) {
        if (!avatarPreview) return;
        if (user.avatarUrl) {
          avatarPreview.innerHTML = `<img src="${user.avatarUrl}" alt="" class="w-full h-full object-cover" />`;
          avatarDeleteBtn?.classList.remove('hidden');
        } else {
          avatarPreview.innerHTML = (user.name || user.email)[0].toUpperCase();
          avatarDeleteBtn?.classList.add('hidden');
        }
      }

      function updateSidebarAvatar(user: any) {
        const userEl = document.getElementById('sidebar-user');
        if (!userEl) return;
        userEl.innerHTML = `
          <div class="flex items-center gap-3">
            ${user.avatarUrl
              ? `<img src="${user.avatarUrl}" alt="" class="w-8 h-8 rounded-full" />`
              : `<div class="w-8 h-8 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-600 dark:text-brand-400 text-sm font-bold">${(user.name || user.email)[0].toUpperCase()}</div>`
            }
            <div class="min-w-0">
              <p class="text-sm font-medium truncate">${user.name || 'Użytkownik'}</p>
              <p class="text-[11px] text-zinc-500 truncate">${user.email}</p>
            </div>
          </div>`;
      }

      // ── Modal open/close ────────────────────────────────────────────────
      function openModal() {
        modal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        avatarAlert?.classList.add('hidden');
        pwAlert?.classList.add('hidden');

        if (cachedUser) {
          if (modalName) modalName.textContent = cachedUser.name || 'Użytkownik';
          if (modalEmail) modalEmail.textContent = cachedUser.email;
          renderAvatar(cachedUser);

          if (!cachedUser.passwordHash && cachedUser.googleId) {
            isGoogleOnly = true;
            if (pwCurrentWrap) pwCurrentWrap.style.display = 'none';
          } else {
            isGoogleOnly = false;
            if (pwCurrentWrap) pwCurrentWrap.style.display = '';
          }
        }

        // Reset password fields
        if (pwCurrent) pwCurrent.value = '';
        if (pwNew) pwNew.value = '';
        if (pwConfirm) pwConfirm.value = '';
        // Collapse password section
        pwSection?.classList.add('hidden');
        pwChevron?.classList.remove('rotate-180');
      }

      function closeModal() {
        modal?.classList.add('hidden');
        document.body.style.overflow = '';
      }

      document.getElementById('sidebar-user')?.addEventListener('click', openModal);
      closeBtn?.addEventListener('click', closeModal);
      modalBg?.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal?.classList.contains('hidden')) closeModal();
      });

      // ── Password toggle ─────────────────────────────────────────────────
      pwToggle?.addEventListener('click', () => {
        const isHidden = pwSection?.classList.contains('hidden');
        if (isHidden) {
          pwSection?.classList.remove('hidden');
          pwChevron?.classList.add('rotate-180');
        } else {
          pwSection?.classList.add('hidden');
          pwChevron?.classList.remove('rotate-180');
        }
      });

      // ── Avatar upload ───────────────────────────────────────────────────
      avatarInput?.addEventListener('change', async () => {
        const file = avatarInput.files?.[0];
        if (!file) return;

        if (file.size > 2 * 1024 * 1024) {
          return showAlertEl(avatarAlert, 'Maks. 2 MB', 'error');
        }
        if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
          return showAlertEl(avatarAlert, 'Dozwolone: JPEG, PNG, WebP', 'error');
        }

        avatarSpinner?.classList.remove('hidden');
        avatarAlert?.classList.add('hidden');

        try {
          const dataUrl = await resizeImage(file, 400);
          const base64 = dataUrl.split(',')[1];

          const res = await fetch('/api/auth/avatar', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: base64, mimeType: file.type }),
          });
          const data = await res.json();

          if (!res.ok) {
            showAlertEl(avatarAlert, data.error || 'Błąd uploadu', 'error');
          } else {
            cachedUser = { ...cachedUser, avatarUrl: data.avatarUrl };
            renderAvatar(cachedUser);
            updateSidebarAvatar(cachedUser);
            showAlertEl(avatarAlert, 'Zdjęcie zaktualizowane!', 'success');
            setTimeout(() => avatarAlert?.classList.add('hidden'), 2000);
          }
        } catch {
          showAlertEl(avatarAlert, 'Błąd połączenia', 'error');
        } finally {
          avatarSpinner?.classList.add('hidden');
          avatarInput.value = '';
        }
      });

      // ── Avatar delete ───────────────────────────────────────────────────
      avatarDeleteBtn?.addEventListener('click', async (e) => {
        e.stopPropagation();
        if (!confirm('Usunąć zdjęcie profilowe?')) return;

        avatarSpinner?.classList.remove('hidden');
        try {
          const res = await fetch('/api/auth/avatar', { method: 'DELETE', credentials: 'include' });
          if (res.ok) {
            cachedUser = { ...cachedUser, avatarUrl: null };
            renderAvatar(cachedUser);
            updateSidebarAvatar(cachedUser);
          }
        } catch {} finally {
          avatarSpinner?.classList.add('hidden');
        }
      });

      // ── Browser-side resize ─────────────────────────────────────────────
      function resizeImage(file: File, maxSize: number): Promise<string> {
        return new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            let w = img.width, h = img.height;
            if (w > maxSize || h > maxSize) {
              const ratio = Math.min(maxSize / w, maxSize / h);
              w = Math.round(w * ratio);
              h = Math.round(h * ratio);
            }
            const canvas = document.createElement('canvas');
            canvas.width = w;
            canvas.height = h;
            canvas.getContext('2d')!.drawImage(img, 0, 0, w, h);
            resolve(canvas.toDataURL(file.type, 0.85));
          };
          img.onerror = reject;
          img.src = URL.createObjectURL(file);
        });
      }

      // ── Password submit ─────────────────────────────────────────────────
      pwSubmit?.addEventListener('click', async () => {
        const currentPassword = pwCurrent?.value || '';
        const newPassword = pwNew?.value || '';
        const newPasswordConfirm = pwConfirm?.value || '';

        if (!newPassword || !newPasswordConfirm) {
          return showAlertEl(pwAlert, 'Wypełnij wszystkie pola', 'error');
        }
        if (newPassword !== newPasswordConfirm) {
          return showAlertEl(pwAlert, 'Nowe hasła nie są identyczne', 'error');
        }
        if (newPassword.length < 8) {
          return showAlertEl(pwAlert, 'Min. 8 znaków', 'error');
        }
        if (!isGoogleOnly && !currentPassword) {
          return showAlertEl(pwAlert, 'Podaj obecne hasło', 'error');
        }

        if (pwSubmit) pwSubmit.disabled = true;
        pwSubmitText?.classList.add('hidden');
        pwSpinner?.classList.remove('hidden');

        try {
          const res = await fetch('/api/auth/change-password', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword, newPassword, newPasswordConfirm }),
          });
          const data = await res.json();
          if (!res.ok) {
            showAlertEl(pwAlert, data.error || 'Błąd', 'error');
          } else {
            showAlertEl(pwAlert, data.message || 'Hasło zmienione!', 'success');
            if (pwCurrent) pwCurrent.value = '';
            if (pwNew) pwNew.value = '';
            if (pwConfirm) pwConfirm.value = '';
          }
        } catch {
          showAlertEl(pwAlert, 'Błąd połączenia', 'error');
        } finally {
          if (pwSubmit) pwSubmit.disabled = false;
          pwSubmitText?.classList.remove('hidden');
          pwSpinner?.classList.add('hidden');
        }
      });

      // ── Init: fetch user, sidebar, logout, cookies ────────────────────
      (async () => {
        try {
          const res = await fetch('/api/auth/me', { credentials: 'include' });
          if (!res.ok) return;
          cachedUser = await res.json();

          if (cachedUser.role === 'ADMIN') {
            document.getElementById('admin-nav-section')?.classList.remove('hidden');
          }

          updateSidebarAvatar(cachedUser);
        } catch {}

        // Logout
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
          try { await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' }); } catch {}
          window.location.href = '/auth/login';
        });

        // Cookies
        document.getElementById('cookies-btn')?.addEventListener('click', () => {
          if (typeof (window as any).openConsentSettings === 'function') {
            (window as any).openConsentSettings();
          }
        });
      })();
    })();
  </script>

  <script>
    // Mobile drawer
    const overlay = document.getElementById('mobile-overlay');
    const openBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const overlayBg = document.getElementById('mobile-overlay-bg');

    function openDrawer() {
      overlay?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    overlayBg?.addEventListener('click', closeDrawer);

    document.getElementById('mobile-logout-btn')?.addEventListener('click', async () => {
      try { await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' }); } catch {}
      window.location.href = '/auth/login';
    });
  </script>

</div>

