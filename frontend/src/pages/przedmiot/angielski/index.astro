---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const totalQuestions = 500;

const topics = [
  { name: 'Słuchanie (Listening)', icon: '🎧', questions: 0, ai: true, desc: 'Nagrania generowane na żywo przez AI — każda sesja inna. Dialogi, wywiady, monologi, podcasty. Akcenty: brytyjski, amerykański, australijski.' },
  { name: 'Gramatyka (Use of English)', icon: '📝', questions: 0, desc: 'Czasy, strona bierna, mowa zależna, zdania warunkowe, inwersja, kolokacje, phrasal verbs.' },
  { name: 'Czytanie (Reading)', icon: '📖', questions: 0, desc: 'Artykuły, wywiady, listy, recenzje — pytania o szczegóły, intencje autora, dobieranie nagłówków.' },
  { name: 'Słownictwo (Vocabulary)', icon: '🔤', questions: 0, desc: 'Człowiek, dom, szkoła, praca, podróże, zdrowie, środowisko, technologia, kultura, życie społeczne.' },
  { name: 'Pisanie (Writing)', icon: '✍️', questions: 0, ai: true, desc: 'E-mail, list formalny, rozprawka, artykuł, recenzja — ocena AI za treść, formę, zakres językowy, poprawność.' },
  { name: 'Środki językowe', icon: '🔧', questions: 0, desc: 'Transformacje zdań, tłumaczenie fragmentów, uzupełnianie luk — typowe zadania z Use of English na maturze.' },
];

// Listening patterns from the generator
const listeningPatterns = [
  { name: 'Krótki dialog', level: 'PP', duration: '30–60s', desc: 'Dwa głosy, codzienna sytuacja, 1 pytanie MCQ', icon: '💬' },
  { name: 'Monolog + Prawda/Fałsz', level: 'PP', duration: '1–2 min', desc: 'Przewodnik, prezentacja, audycja — 3-4 stwierdzenia T/F', icon: '🎙️' },
  { name: 'Wywiad + MCQ', level: 'PP/PR', duration: '2–3 min', desc: 'Rozmowa z ekspertem — 3-4 pytania wielokrotnego wyboru', icon: '🎤' },
  { name: 'Uzupełnij luki (Gap Fill)', level: 'PR', duration: '2–3 min', desc: 'Wykład, raport, wiadomości — 4-5 pytań: wpisz usłyszany szczegół', icon: '⎵' },
  { name: 'Rozszerzony mieszany', level: 'PR', duration: '3–4 min', desc: 'Panel dyskusyjny, audycja radiowa — 5-6 pytań różnych typów', icon: '🧩' },
];

const accents = [
  { flag: '🇬🇧', name: 'Brytyjski', voices: 'Kobieta + Mężczyzna (Neural2)' },
  { flag: '🇺🇸', name: 'Amerykański', voices: 'Kobieta + Mężczyzna (Neural2)' },
  { flag: '🇦🇺', name: 'Australijski', voices: 'Kobieta + Mężczyzna (Neural2)' },
];

const questionTypes = [
  { icon: '🎧', name: 'Słuchanie AI', desc: 'Nagrania generowane na żywo, max 2 odtworzenia jak na maturze', badge: 'AI LIVE' },
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Rozumienie tekstu, gramatyka, słownictwo' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Stwierdzenia do nagrania lub tekstu' },
  { icon: '⎵', name: 'Uzupełnij luki', desc: 'Gramatyka, słownictwo, transformacje' },
  { icon: '⇄', name: 'Dopasuj', desc: 'Nagłówki do akapitów, zdania do luk' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '✎', name: 'Otwarte', desc: 'Krótkie odpowiedzi na pytania do tekstu', badge: 'AI' },
  { icon: '✍️', name: 'Wypracowania', desc: 'E-mail, rozprawka, artykuł — ocena AI wg CKE', badge: 'AI' },
];

const faq = [
  { q: 'Jak działa słuchanie generowane przez AI?', a: 'Za każdym razem AI (Claude Sonnet) generuje świeży transkrypt — dialog, wywiad, monolog lub audycję. Następnie Google Text-to-Speech syntezuje głos w wybranym akcencie (brytyjski, amerykański, australijski) z różnymi lektorami. Otrzymujesz max 2 odtworzenia, dokładnie jak na prawdziwej maturze CKE. Każda sesja jest unikalna — nigdy nie powtórzysz tego samego nagrania.' },
  { q: 'Jakie akcenty są dostępne w nagraniach?', a: 'Trzy akcenty: brytyjski (en-GB), amerykański (en-US) i australijski (en-AU). Każdy ma głosy kobiece i męskie (Google Neural2 — najwyższa jakość). Na prawdziwej maturze CKE dominuje akcent brytyjski, ale amerykański też się pojawia.' },
  { q: 'Ile nagrań mogę wysłuchać?', a: 'Nieograniczoną liczbę. Każde nagranie generowane jest na żywo, więc baza jest nieskończona. Jedyne ograniczenie to kredyty AI (600/miesiąc w subskrypcji) — jedno nagranie = 1 kredyt.' },
  { q: 'Czym różni się matura z angielskiego PP od PR?', a: 'PP (B1/B1+): prostsze słownictwo, wyraźna wymowa, wolniejsze tempo, tematy codzienne. PR (B2/C1): złożone słownictwo, naturalny akcent, szybsze tempo, tematy akademickie i społeczne. Na platformie wybierasz poziom — algorytm adaptacyjny dostosowuje trudność.' },
  { q: 'Czy AI ocenia wypracowania z angielskiego?', a: 'Tak. AI ocenia 4 kryteria CKE: treść (0-4 pkt), forma (0-2 pkt), zakres językowy (0-2 pkt), poprawność (0-2 pkt) — łącznie do 10 punktów. Dostajesz feedback w 30 sekund z konkretnymi wskazówkami.' },
  { q: 'Jak przygotować się do matury z angielskiego w 3 miesiące?', a: '(1) Codziennie 1 nagranie listening (10 min) — AI generuje świeże za każdym razem. (2) 15 min gramatyki i słownictwa z adaptacyjnym algorytmem. (3) Co tydzień jedno wypracowanie — AI oceni w 30 sekund. (4) Spaced Repetition na phrasal verbs i kolokacje — 5 min dziennie. (5) Ostatni tydzień: pełne arkusze z czasem.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'biologia', name: 'Biologia', icon: '🧬' }, { slug: 'chemia', name: 'Chemia', icon: '⚗️' },
  { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' }, { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' }, { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---
<Base title="Matura z Angielskiego 2026 — Słuchanie AI, Gramatyka, Wypracowania | Matury Online">
<!-- NAV -->
<Header navLinks={[
  { href: '#listening', label: 'Słuchanie AI' },
  { href: '#tematy', label: 'Tematy' },
  { href: '#typy-zadan', label: 'Typy zadań' },
  { href: '#cennik', label: 'Cennik' },
  { href: '#faq', label: 'FAQ' },
]} />

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-red-500/10 dark:bg-red-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-rose-500/10 dark:bg-rose-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-400 text-sm font-semibold mb-8">
        <span class="text-2xl">🇬🇧</span> Język angielski · PP + PR · <span data-qcount-min="angielski">{totalQuestions}+</span> pytań · <span class="font-bold">Słuchanie AI</span>
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z angielskiego<br/><span class="bg-gradient-to-r from-red-500 to-rose-500 bg-clip-text text-transparent">z nieograniczonym listeningiem</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">Flagowa funkcja niedostępna nigdzie indziej</strong> — AI generuje świeże nagrania na żywo z autentycznymi akcentami. Plus gramatyka, słownictwo, czytanie i wypracowania oceniane przez AI według <strong class="text-zinc-900 dark:text-zinc-100">kryteriów CKE</strong>.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć angielski — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100" data-qcount-min="angielski">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">∞</div><div class="text-sm text-zinc-500 mt-1">nagrań AI</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">3</div><div class="text-sm text-zinc-500 mt-1">akcenty</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PP+PR</div><div class="text-sm text-zinc-500 mt-1">oba poziomy</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">30s</div><div class="text-sm text-zinc-500 mt-1">ocena AI</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-red-500 to-rose-500">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z angielskiego — środa/czwartek, 6–7 maja 2026</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do matury z angielskiego zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Listening to najtrudniejsza część matury — i jedyna, której <strong class="text-white">nie powtórzysz</strong>. Ćwicz codziennie.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-red-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij słuchać →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-06T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- LISTENING AI — FLAGSHIP                                                 -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section id="listening" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 text-xs font-semibold mb-4">🎧 UNIKALNE NA RYNKU · AI LIVE</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Nieograniczone nagrania do słuchania — AI tworzy je specjalnie dla Ciebie</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">
        Żadna inna platforma w Polsce tego nie ma. Za każdym razem AI generuje świeży transkrypt, a Google Text-to-Speech syntezuje głos w autentycznym akcencie. Każda sesja inna, każde nagranie unikalne.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <!-- Left: features -->
      <div>
        <h3 class="font-display font-bold text-xl mb-6">Jak to działa?</h3>
        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-2xl bg-red-500 text-white flex items-center justify-center font-display font-bold shadow-lg shadow-red-500/25">1</div>
            <div><div class="font-display font-semibold text-sm">AI generuje transkrypt</div><div class="text-xs text-zinc-500">Claude Sonnet tworzy unikalny dialog, wywiad lub monolog na wybrany temat i poziom (B1+–C1).</div></div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-2xl bg-red-500 text-white flex items-center justify-center font-display font-bold shadow-lg shadow-red-500/25">2</div>
            <div><div class="font-display font-semibold text-sm">Google TTS syntezuje głos</div><div class="text-xs text-zinc-500">Neural2 — najwyższa jakość. Różni lektorzy M/F w akcencie brytyjskim, amerykańskim lub australijskim.</div></div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-2xl bg-red-500 text-white flex items-center justify-center font-display font-bold shadow-lg shadow-red-500/25">3</div>
            <div><div class="font-display font-semibold text-sm">Słuchasz i odpowiadasz</div><div class="text-xs text-zinc-500">Max 2 odtworzenia jak na prawdziwej maturze CKE. Pytania: MCQ, True/False, Gap Fill — mieszane.</div></div>
          </div>
        </div>

        <!-- Accents -->
        <h3 class="font-display font-bold text-lg mb-4">Dostępne akcenty</h3>
        <div class="space-y-2 mb-8">
          {accents.map(a => (
            <div class="flex items-center gap-3 p-3 rounded-xl bg-white dark:bg-surface-800">
              <span class="text-2xl">{a.flag}</span>
              <div><div class="font-semibold text-sm">{a.name}</div><div class="text-xs text-zinc-500">{a.voices}</div></div>
            </div>
          ))}
        </div>

        <!-- Listening patterns -->
        <h3 class="font-display font-bold text-lg mb-4">5 formatów nagrań CKE</h3>
        <div class="space-y-2">
          {listeningPatterns.map(p => (
            <div class="flex items-start gap-3 p-3 rounded-xl bg-white dark:bg-surface-800">
              <span class="text-xl mt-0.5">{p.icon}</span>
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="font-semibold text-sm">{p.name}</span>
                  <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded-full ${p.level === 'PR' ? 'bg-red-100 dark:bg-red-900/30 text-red-600' : p.level === 'PP/PR' ? 'bg-amber-100 dark:bg-amber-900/30 text-amber-600' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-600'}`}>{p.level}</span>
                  <span class="text-[10px] text-zinc-400">{p.duration}</span>
                </div>
                <p class="text-xs text-zinc-500">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Player mockup -->
      <div class="glass-card p-6 bg-gradient-to-br from-white to-zinc-50 dark:from-surface-800 dark:to-surface-900 sticky top-28">
        <div class="text-xs text-zinc-500 mb-3 font-medium">Usłyszysz wywiad z ekspertką ds. klimatu. Zadanie 14.</div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-red-50 to-rose-50 dark:from-red-900/20 dark:to-rose-900/20 mb-5">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-red-500 to-rose-600 flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
            <div class="flex-1">
              <div class="h-10 flex items-center gap-[2px] mb-1">
                {Array.from({length:40}).map((_, i) => {
                  const h = 20 + Math.sin(i*0.7)*15 + Math.cos(i*1.3)*10;
                  const filled = i < 15;
                  return <div class={`flex-1 rounded-full ${filled ? 'bg-red-500' : 'bg-zinc-200 dark:bg-zinc-700'}`} style={`height:${Math.max(4,h)}%`}></div>;
                })}
              </div>
              <div class="flex justify-between text-[10px] text-zinc-500 font-mono">
                <span>0:32 / 2:14</span>
                <span>⚪⚫ 1 odtworzenie</span>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-2">
          <div class="p-3 rounded-xl bg-zinc-100 dark:bg-surface-700 text-xs">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-5 h-5 rounded-full bg-red-500 text-white text-[9px] flex items-center justify-center font-bold">1</span>
              <span class="font-semibold">According to the expert, the main cause of...</span>
              <span class="ml-auto text-zinc-400">1 pkt</span>
            </div>
            <div class="grid grid-cols-4 gap-1 mt-2">
              {['A','B','C','D'].map(l => (
                <div class={`px-2 py-1 rounded text-center text-[10px] ${l==='B' ? 'bg-red-500 text-white' : 'bg-white dark:bg-surface-800'}`}>{l}</div>
              ))}
            </div>
          </div>
          <div class="p-3 rounded-xl bg-zinc-100 dark:bg-surface-700 text-xs">
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-red-500 text-white text-[9px] flex items-center justify-center font-bold">2</span>
              <span>True or False: The speaker believes that...</span>
            </div>
            <div class="flex gap-2 mt-2">
              <div class="px-3 py-1 rounded bg-green-500 text-white text-[10px] font-bold">T</div>
              <div class="px-3 py-1 rounded bg-white dark:bg-surface-800 text-[10px]">F</div>
            </div>
          </div>
          <div class="p-3 rounded-xl bg-zinc-100 dark:bg-surface-700 text-xs opacity-60">
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-red-500 text-white text-[9px] flex items-center justify-center font-bold">3</span>
              <span>Fill in: The expert recommends ________</span>
            </div>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 text-[10px] text-zinc-500">
          <span class="px-2 py-0.5 rounded bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 font-bold">🤖 AI LIVE</span>
          <span>Nagranie unikalne — każdej sesji inne</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TEMATY -->
<section id="tematy" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Pełny zakres matury z angielskiego</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Słuchanie, gramatyka, czytanie, słownictwo, pisanie, środki językowe — wszystko w jednej platformie.</p>
    </div>
