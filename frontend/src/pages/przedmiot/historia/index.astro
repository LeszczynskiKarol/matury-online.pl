---
import Base from '../../../layouts/Base.astro';
import { ThemeToggle } from '../../../components/ui/ThemeToggle';

const eras = [
  { era: 'Starożytność', icon: '🏛️', topics: [
    { name: 'Pradzieje i starożytny Wschód', q: 8 },
    { name: 'Starożytna Grecja', q: 11 },
    { name: 'Starożytny Rzym', q: 12 },
    { name: 'Bizancjum i świat islamu', q: 9 },
  ]},
  { era: 'Średniowiecze', icon: '⚔️', topics: [
    { name: 'Europa wczesnego średniowiecza', q: 12 },
    { name: 'Kultura średniowiecza', q: 10 },
    { name: 'Europa późnego średniowiecza', q: 7 },
    { name: 'Polska piastowska (X–XII w.)', q: 11 },
    { name: 'Polska w XIV–XV w.', q: 12 },
  ]},
  { era: 'Nowożytność (XVI–XVIII w.)', icon: '🗺️', topics: [
    { name: 'Odkrycia geograficzne i renesans', q: 7 },
    { name: 'Reformacja i jej skutki', q: 9 },
    { name: 'Europa w XVI–XVII w.', q: 8 },
    { name: 'Rzeczpospolita w XVI w.', q: 11 },
    { name: 'Rzeczpospolita w XVII w.', q: 10 },
    { name: 'Europa w dobie oświecenia', q: 7 },
    { name: 'Rewolucje XVIII w.', q: 8 },
    { name: 'Rzeczpospolita w XVIII w. i upadek', q: 9 },
  ]},
  { era: 'XIX wiek', icon: '🏭', topics: [
    { name: 'Epoka napoleońska', q: 11 },
    { name: 'Europa po kongresie wiedeńskim', q: 10 },
    { name: 'Ziemie polskie 1815–1848', q: 10 },
    { name: 'Powstanie styczniowe i następstwa', q: 8 },
    { name: 'Ziemie polskie pod zaborami (II poł. XIX w.)', q: 13 },
    { name: 'Europa i świat II poł. XIX w.', q: 9 },
  ]},
  { era: 'XX wiek i współczesność', icon: '🌍', topics: [
    { name: 'I wojna światowa i sprawa polska', q: 16 },
    { name: 'II Rzeczpospolita', q: 16 },
    { name: 'Świat międzywojenny i totalitaryzmy', q: 16 },
    { name: 'II wojna światowa i okupacja', q: 38 },
    { name: 'Polska 1944–1989 (PRL)', q: 39 },
    { name: 'III Rzeczpospolita', q: 30 },
    { name: 'Zimna wojna i przemiany cywilizacyjne', q: 23 },
  ]},
];

const allTopics = eras.flatMap(e => e.topics);
const totalQuestions = allTopics.reduce((s, t) => s + t.q, 0); // 399
const topTopics = [...allTopics].sort((a, b) => b.q - a.q).slice(0, 6);

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o daty, postacie, wydarzenia, przyczyny i skutki' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń historycznych' },
  { icon: '↕', name: 'Chronologia', desc: 'Uporządkuj wydarzenia chronologicznie' },
  { icon: '⇄', name: 'Dopasuj pary', desc: 'Połącz postacie z wydarzeniami, daty z faktami' },
  { icon: '◫', name: 'Wiązka źródłowa', desc: 'Analiza fragmentu źródła z pytaniami mieszanymi' },
  { icon: '📈', name: 'Analiza danych', desc: 'Mapy, wykresy, tabele statystyczne, ikonografia' },
  { icon: '✎', name: 'Otwarte', desc: 'Wyjaśnij przyczyny, oceń skutki — ocena AI', badge: 'AI' },
];

const faq = [
  { q: 'Jakie epoki historyczne są na maturze 2026?', a: `Matura z historii obejmuje pełen zakres: od pradziejów i starożytności, przez średniowiecze, nowożytność (XVI–XVIII w.), wiek XIX, po XX wiek i współczesność. Na platformie mamy 30 tematów w 5 epokach — łącznie ${totalQuestions}+ pytań. Największe zestawy: PRL (39), II wojna światowa (38), III RP (30).` },
  { q: 'Czy matura z historii jest tylko na poziomie rozszerzonym?', a: 'Tak. Historia jest wyłącznie przedmiotem dodatkowym (PR). Egzamin: 180 minut, do 60 punktów. Składa się z zadań zamkniętych, analizy źródeł historycznych (teksty, mapy, ikonografia) i zadań otwartych.' },
  { q: 'Ile pytań z historii jest na platformie?', a: `${totalQuestions}+ pytań na 30 tematów w 5 epokach. Największe zestawy: Polska 1944–1989 PRL (39), II wojna światowa i okupacja (38), III Rzeczpospolita (30), Zimna wojna (23). Baza rozbudowywana regularnie.` },
  { q: 'Czy są zadania z analizą źródeł?', a: 'Tak. Mamy wiązki źródłowe — fragment tekstu historycznego (kronika, traktat, akt prawny, pamiętnik) z zestawem pytań różnych typów. To kluczowy format na maturze z historii. AI ocenia zadania otwarte: przyczyny, skutki, porównania.' },
  { q: 'Jak przygotować się do matury z historii w 3 miesiące?', a: '(1) Test diagnostyczny — system znajdzie luki w 30 tematach. (2) 30-45 min dziennie — algorytm adaptacyjny skupia się na najsłabszych epokach. (3) Chronologię ćwicz przez Spaced Repetition — 10 min dziennie. (4) Źródła historyczne: ćwicz analizę regularnie. (5) Ostatni tydzień: pełne arkusze z czasem.' },
  { q: 'Czy AI ocenia zadania otwarte z historii?', a: 'Tak. AI sprawdza: poprawność merytoryczną, znajomość faktów, logikę argumentacji, użycie terminologii historycznej. Przy błędzie wskazuje co poprawić i podaje wzorcową odpowiedź.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' }, { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' }, { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---
<Base title="Matura z Historii 2026 — Starożytność, Średniowiecze, XX wiek, Zadania AI | Matury Online">
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20"><span class="text-white font-display font-bold text-lg">M</span></div><span class="font-display font-bold text-xl hidden sm:block">Matury Online</span></a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#epoki" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Epoki</a>
      <a href="#typy-zadan" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
      <a href="#cennik" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cennik</a>
      <a href="#faq" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-3"><ThemeToggle client:load /><a href="/auth/login" class="btn-ghost text-sm py-2 px-4 hidden sm:inline-flex">Zaloguj się</a><a href="/auth/register" class="btn-primary text-sm py-2 px-5">Rozpocznij naukę</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-stone-500/10 dark:bg-stone-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-amber-500/10 dark:bg-amber-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-stone-100 dark:bg-stone-900/20 text-stone-700 dark:text-stone-400 text-sm font-semibold mb-8">
        <span class="text-2xl">🏛️</span> Historia · PR · {totalQuestions}+ pytań · 30 tematów
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z historii<br/><span class="bg-gradient-to-r from-stone-500 to-amber-600 bg-clip-text text-transparent">od pradziejów po III RP</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">30 tematów</strong> w 5 epokach — starożytność, średniowiecze, nowożytność, XIX wiek, XX wiek. Analiza źródeł, chronologia, zadania otwarte oceniane przez <strong class="text-zinc-900 dark:text-zinc-100">AI</strong>. Spaced Repetition na daty, postacie, wydarzenia.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć historię — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">5</div><div class="text-sm text-zinc-500 mt-1">epok</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">30</div><div class="text-sm text-zinc-500 mt-1">tematów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">AI</div><div class="text-sm text-zinc-500 mt-1">ocena otwartych</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-stone-600 to-amber-600">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z historii — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Historia to <strong class="text-white">tylko poziom rozszerzony</strong>. Egzamin: 180 minut, do 60 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-stone-700 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-20T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- NAJWIĘKSZE ZESTAWY -->
<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-2xl md:text-3xl mb-3">Tematy z największą bazą pytań</h2>
      <p class="text-zinc-600 dark:text-zinc-400">Najczęściej pojawiające się na maturze — i u nas najlepiej pokryte.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {topTopics.map(t => (
        <div class="glass-card p-5 text-center group hover:border-stone-500/30 transition-all">
          <div class="font-display font-extrabold text-2xl text-stone-600 dark:text-stone-400 mb-1">{t.q}</div>
          <h3 class="font-display font-bold text-sm">{t.name}</h3>
          <p class="text-[10px] text-zinc-400 mt-1">pytań</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- EPOKI — PEŁNA LISTA -->
<section id="epoki" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">5 epok · 30 tematów — pełny zakres matury</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Od pradziejów po III Rzeczpospolitą. Historia Polski i historia powszechna w równowadze — jak na prawdziwej maturze CKE.</p>
    </div>

    <div class="space-y-8">
      {eras.map(era => (
        <div>
          <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
            <span class="w-8 h-8 rounded-lg bg-stone-100 dark:bg-stone-900/30 flex items-center justify-center text-sm">{era.icon}</span>
            {era.era}
            <span class="text-xs text-zinc-400 font-normal ml-2">{era.topics.reduce((s, t) => s + t.q, 0)} pytań</span>
          </h3>
          <div class="flex flex-wrap gap-2">
            {era.topics.map(t => (
              <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-2xl bg-white dark:bg-surface-800 border border-zinc-200 dark:border-zinc-700 hover:border-stone-400 dark:hover:border-stone-600 transition-all">
                <span class="font-display font-semibold text-sm">{t.name}</span>
                <span class="text-xs font-bold text-stone-600 dark:text-stone-400 bg-stone-100 dark:bg-stone-900/30 px-2 py-0.5 rounded-full">{t.q}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TYPY ZADAŃ -->
<section id="typy-zadan" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Typy zadań maturalnych z historii</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Chronologia, analiza źródeł, mapy, ikonografia — formaty identyczne z arkuszem CKE.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {questionTypes.map(t => (
        <div class="glass-card p-5 relative group hover:border-stone-500/30 transition-all">
          {t.badge && <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-bold bg-stone-100 dark:bg-stone-900/30 text-stone-700 dark:text-stone-400">{t.badge}</span>}
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{t.icon}</div>
          <h3 class="font-display font-bold text-sm mb-1">{t.name}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AI GRADING DEMO -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-stone-100 dark:bg-stone-900/30 text-stone-700 dark:text-stone-400 text-xs font-semibold mb-4">🤖 OCENA AI</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">AI ocenia odpowiedzi otwarte z historii</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Sprawdza fakty, argumentację, terminologię historyczną i kompletność odpowiedzi.</p>
    </div>
    <div class="max-w-4xl mx-auto glass-card p-8">
      <div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-700">
        <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Zadanie otwarte · Historia PR · Polska 1944–1989 (PRL)</div>
        <p class="font-display text-lg font-semibold">Podaj dwie przyczyny wprowadzenia stanu wojennego 13 grudnia 1981 roku i oceń jego skutki dla opozycji demokratycznej.</p>
      </div>
      <div class="mb-6 p-4 rounded-2xl bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800/30">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-2">Twoja odpowiedź</div>
        <p class="text-sm text-zinc-700 dark:text-zinc-300">Przyczyny: (1) narastające napięcie społeczne i rosnąca siła „Solidarności", która liczyła ok. 10 mln członków i stanowiła realną alternatywę władzy; (2) presja Moskwy — ZSRR obawiał się „efektu domina" w bloku wschodnim i groził interwencją zbrojną. Skutki: stan wojenny zdelegalizował Solidarność i internował ok. 10 tys. działaczy, ale nie zniszczył opozycji — podziemne struktury (m.in. prasa, RKW) działały przez całe lata 80., co ostatecznie doprowadziło do Okrągłego Stołu w 1989 r.</p>
      </div>
      <div class="mb-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Ocena AI</div>
          <div class="flex items-baseline gap-1"><span class="font-display font-extrabold text-3xl text-green-500">4</span><span class="text-zinc-500 text-sm">/ 4 pkt</span></div>
        </div>
        <div class="space-y-2">
          {[
            ['Przyczyna 1', 'Siła Solidarności — poprawnie: 10 mln członków, alternatywa władzy'],
            ['Przyczyna 2', 'Presja ZSRR — poprawnie: groźba interwencji, efekt domina'],
            ['Skutki krótkoterminowe', 'Delegalizacja, internowania — poprawne fakty'],
            ['Skutki długoterminowe', 'Podziemie → Okrągły Stół — trafna ocena'],
          ].map(([step, detail], i) => (
            <div class="flex items-center gap-3 p-3 rounded-xl bg-green-50 dark:bg-green-900/10">
              <span class="w-6 h-6 rounded-full bg-green-500 text-white text-xs flex items-center justify-center font-bold">✓</span>
              <div class="flex-1"><span class="text-sm font-medium">{step}</span><span class="text-xs text-zinc-500 ml-2">{detail}</span></div>
              <span class="text-xs font-bold text-green-600">1 pkt</span>
            </div>
          ))}
        </div>
      </div>
      <div class="p-4 rounded-2xl bg-green-50 dark:bg-green-900/10 border border-green-200 dark:border-green-800/30">
