---
import Base from '../../../layouts/Base.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';


// ── DANE PRZEDMIOTU ──────────────────────────────────────────────────────
const subject = {
  slug: 'polski',
  name: 'Język polski',
  icon: '📚',
  color: '#6366f1',
  level: 'PP + PR',
};

// ── EPOKI I LEKTURY ──────────────────────────────────────────────────────
const epochs = [
  {
    name: 'Starożytność', dateFrom: '4000 p.n.e.', dateTo: '476 n.e.', questions: 142,
    works: [
      { name: 'Antygona', author: 'Sofokles', q: 142 },
      { name: 'Król Edyp', author: 'Sofokles', q: 175 },
      { name: 'Odyseja', author: 'Homer', q: 4 },
      { name: 'Iliada', author: 'Homer', q: 1 },
    ],
  },
  {
    name: 'Średniowiecze', dateFrom: '476', dateTo: '1450', questions: 165,
    works: [
      { name: 'Bogurodzica', author: null, q: 50 },
      { name: 'Pieśń o Rolandzie', author: null, q: 50 },
      { name: 'Boska komedia', author: 'Dante Alighieri', q: 60 },
    ],
  },
  {
    name: 'Renesans', dateFrom: '1450', dateTo: '1600', questions: 13,
    works: [
      { name: 'Treny', author: 'Jan Kochanowski', q: 62 },
      { name: 'Makbet', author: 'William Szekspir', q: 92 },
      { name: 'Odprawa posłów greckich', author: 'Jan Kochanowski', q: 2 },
      { name: 'Kazania sejmowe', author: 'Piotr Skarga', q: 50 },
    ],
  },
  {
    name: 'Barok', dateFrom: '1600', dateTo: '1764', questions: 73,
    works: [
      { name: 'Pamiętniki', author: 'Jan Chryzostom Pasek', q: 60 },
    ],
  },
  {
    name: 'Oświecenie', dateFrom: '1764', dateTo: '1822', questions: 17,
    works: [
      { name: 'Świętoszek', author: 'Molier', q: 50 },
      { name: 'Skąpiec', author: 'Molier', q: 50 },
      { name: 'Powrót posła', author: 'Julian Ursyn Niemcewicz', q: 50 },
    ],
  },
  {
    name: 'Romantyzm', dateFrom: '1822', dateTo: '1863', questions: 21,
    works: [
      { name: 'Dziady cz. III', author: 'Adam Mickiewicz', q: 208 },
      { name: 'Nie-Boska komedia', author: 'Zygmunt Krasiński', q: 51 },
      { name: 'Pan Tadeusz', author: 'Adam Mickiewicz', q: 76 },
      { name: 'Ballady i romanse', author: 'Adam Mickiewicz', q: 50 },
      { name: 'Konrad Wallenrod', author: 'Adam Mickiewicz', q: 64 },
      { name: 'Kordian', author: 'Juliusz Słowacki', q: 50 },
    ],
  },
  {
    name: 'Pozytywizm', dateFrom: '1863', dateTo: '1890', questions: 96,
    works: [
      { name: 'Lalka', author: 'Bolesław Prus', q: 134 },
      { name: 'Nad Niemnem', author: 'Eliza Orzeszkowa', q: 50 },
      { name: 'Zbrodnia i kara', author: 'Fiodor Dostojewski', q: 72 },
      { name: 'Chłopi', author: 'Władysław Reymont', q: 51 },
    ],
  },
  {
    name: 'Młoda Polska', dateFrom: '1890', dateTo: '1918', questions: 14,
    works: [
      { name: 'Wesele', author: 'Stanisław Wyspiański', q: 65 },
      { name: 'Ludzie bezdomni', author: 'Stefan Żeromski', q: 121 },
    ],
  },
  {
    name: 'Dwudziestolecie międzywojenne', dateFrom: '1918', dateTo: '1939', questions: 12,
    works: [
      { name: 'Ferdydurke', author: 'Witold Gombrowicz', q: 62 },
      { name: 'Przedwiośnie', author: 'Stefan Żeromski', q: 48 },
      { name: 'Sklepy cynamonowe', author: 'Bruno Schulz', q: 66 },
    ],
  },
  {
    name: 'Współczesność', dateFrom: '1945', dateTo: 'dziś', questions: 19,
    works: [
      { name: 'Tango', author: 'Sławomir Mrożek', q: 62 },
      { name: 'Dżuma', author: 'Albert Camus', q: 99 },
      { name: 'Medaliony', author: 'Zofia Nałkowska', q: 50 },
      { name: 'Zdążyć przed Panem Bogiem', author: 'Hanna Krall', q: 60 },
      { name: 'Inny świat', author: 'Gustaw Herling-Grudziński', q: 50 },
    ],
  },
];

const extraTopics = [
  { name: 'Język w użyciu', questions: 399, desc: 'Gramatyka, składnia, frazeologia, słowotwórstwo, odmiana, norma językowa' },
  { name: 'Teoria literatury', questions: 76, desc: 'Środki stylistyczne, gatunki, prądy, konwencje, narracja, kompozycja' },
  { name: 'Pisanie (rozprawka, esej)', questions: 24, desc: 'Rozprawka problemowa, interpretacja, esej — oceniane przez AI wg CKE' },
];

const totalQuestions = epochs.reduce((s, e) => s + e.works.reduce((ws, w) => ws + w.q, 0), 0)
  + extraTopics.reduce((s, t) => s + t.questions, 0);

// ── TYPY ZADAŃ DLA POLSKIEGO ─────────────────────────────────────────────
const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o treść lektury, epokę, prąd literacki' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi dotyczące tekstu' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń o lekturach i epokach' },
  { icon: '✎', name: 'Otwarte', desc: 'Krótkie odpowiedzi o bohaterach, motywach, symbolice', badge: 'AI' },
  { icon: '📄', name: 'Wypracowania', desc: 'Rozprawka problemowa i interpretacja — ocena AI wg 6 kryteriów CKE', badge: 'AI' },
  { icon: '⎵', name: 'Uzupełnij luki', desc: 'Wpisz brakujące pojęcia z teorii literatury' },
  { icon: '⇄', name: 'Dopasuj pary', desc: 'Połącz autora z dziełem, postać z lekturą' },
  { icon: '↕', name: 'Ustaw kolejność', desc: 'Uporządkuj epoki, wydarzenia fabularne' },
  { icon: '◫', name: 'Wiązka tekstu', desc: 'Fragment tekstu literackiego z pytaniami mieszanymi' },
  { icon: '✗', name: 'Znajdź błąd', desc: 'Wskaż błąd w analizie lub interpretacji' },
];

// ── POPULARNE LEKTURY (TOP 8 po liczbie pytań) ───────────────────────────
const topWorks = epochs.flatMap(e => e.works.map(w => ({ ...w, epoch: e.name })))
  .sort((a, b) => b.q - a.q)
  .slice(0, 8);

// ── FAQ ──────────────────────────────────────────────────────────────────
const faq = [
  {
    q: 'Jakie lektury obowiązkowe są na maturze z polskiego 2026?',
    a: `Na maturze 2026 obowiązuje pełen kanon lektur z podstawy programowej CKE — od Antygony i Bogurodzicy, przez Dziady cz. III, Lalkę, Wesele, po Dżumę i Tango. Na platformie mamy pytania do każdej obowiązkowej lektury z podziałem na epoki. Możesz filtrować pytania po konkretnej lekturze, np. przećwiczyć tylko Dziady cz. III (208 pytań) lub Lalkę (134 pytania).`,
  },
  {
    q: 'Jak AI ocenia wypracowanie z polskiego?',
    a: 'AI (Claude Sonnet) ocenia według dokładnych 6 kryteriów CKE: realizacja tematu (0-2 pkt), teza i argumentacja (0-12 pkt), kompozycja (0-8 pkt), styl tekstu (0-4 pkt), język (0-6 pkt), zapis (0-4 pkt) — łącznie do 36 punktów. Dostajesz ocenę każdego kryterium z uzasadnieniem, listę mocnych stron i konkretne wskazówki do poprawy. Czas oceny: ok. 30 sekund.',
  },
  {
    q: 'Czym różni się matura z polskiego PP od PR?',
    a: 'Poziom podstawowy (PP) obejmuje test z rozumienia tekstu, naukę o języku i krótkie wypracowanie (rozprawkę 250+ słów). Poziom rozszerzony (PR) to dłuższe wypracowanie — rozprawka problemowa lub interpretacja porównawcza (min. 300 słów), oceniane według 6 kryteriów. Na platformie masz pytania do obu poziomów — możesz filtrować PP, PR lub mieszać.',
  },
  {
    q: 'Ile pytań z języka polskiego jest na platformie?',
    a: `Aktualnie mamy ${totalQuestions}+ pytań z polskiego, obejmujących wszystkie 10 epok literackich, ponad 30 lektur obowiązkowych, teorię literatury, naukę o języku i zadania pisemne. Pytania są autorskie, zgodne z podstawą programową CKE 2026. Baza jest regularnie rozbudowywana.`,
  },
  {
    q: 'Jak przygotować się do rozprawki maturalnej z polskiego?',
    a: 'Najlepsza metoda: (1) Przećwicz pytania zamknięte z lektur, żeby dobrze znać treść i bohaterów. (2) Pisz co najmniej jedną rozprawkę tygodniowo na platformie — AI oceni ją w 30 sekund i wskaże co poprawić. (3) Skup się na najsłabszym kryterium CKE (najczęściej kompozycja lub argumentacja). (4) Powtarzaj kluczowe cytaty przez Spaced Repetition.',
  },
  {
    q: 'Czy platforma pomoże mi zdobyć 100% z matury z polskiego?',
    a: 'System adaptacyjnej trudności utrzymuje Cię w strefie ~70% poprawnych odpowiedzi, co jest optymalną strefą nauki. Średni wzrost wyniku po 30 dniach regularnej pracy to +18 punktów procentowych. Wypracowanie oceniane przez AI pozwala systematycznie poprawiać każde kryterium CKE — bez czekania tygodnia na feedback od nauczyciela.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// ── INNE PRZEDMIOTY (do cross-linkowania) ────────────────────────────────
const otherSubjects = [
  { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' },
  { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' },
  { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' },
  { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' },
  { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---

<Base title="Matura z Polskiego 2026 — Lektury, Epoki, Wypracowania AI | Matury Online">

<!-- NAV -->
<Header navLinks={[
  { href: '#tematy', label: 'Tematy' },
  { href: '#typy-zadan', label: 'Typy zadań' },
  { href: '#cennik', label: 'Cennik' },
  { href: '#faq', label: 'FAQ' },
]} />
  

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- HERO                                                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-indigo-500/10 dark:bg-indigo-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-purple-500/10 dark:bg-purple-500/5 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(99,102,241,0.08),transparent_60%)]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in">
      <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">
        ← Wszystkie przedmioty
      </a>
    </div>

    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-indigo-100 dark:bg-indigo-900/20 text-indigo-700 dark:text-indigo-400 text-sm font-semibold mb-8">
        <span class="text-2xl">📚</span>
        Język polski · PP + PR · <span data-qcount-min="polski">{totalQuestions}+</span> pytań
      </div>
    </div>

    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z polskiego<br/>
      <span class="text-gradient">bez stresu</span>
    </h1>

    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">10 epok literackich</strong>, <strong class="text-zinc-900 dark:text-zinc-100">30+ lektur obowiązkowych</strong>, wypracowania oceniane przez AI według <strong class="text-zinc-900 dark:text-zinc-100">6 kryteriów CKE</strong> w 30 sekund. Teoria literatury, nauka o języku, rozprawka — wszystko w jednym miejscu.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">
        Zacznij ćwiczyć polski — 49 zł/mies.
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">10</div>
        <div class="text-sm text-zinc-500 mt-1">epok literackich</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">30+</div>
        <div class="text-sm text-zinc-500 mt-1">lektur</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100" data-qcount-min="polski">{totalQuestions}+</div>
        <div class="text-sm text-zinc-500 mt-1">pytań</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">36</div>
        <div class="text-sm text-zinc-500 mt-1">pkt rozprawka</div>
      </div>
      <div class="text-center">
        <div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">30s</div>
        <div class="text-sm text-zinc-500 mt-1">ocena AI</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- COUNTDOWN                                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="py-12 bg-gradient-to-r from-indigo-500 to-purple-600">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">
      ⏰ Matura z języka polskiego — poniedziałek, 4 maja 2026, godz. 9:00
    </p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">
      Do matury z polskiego zostało:
    </h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div>
      </div>
    </div>
    <p class="text-white/80 text-sm mt-6">
      Język polski to <strong class="text-white">pierwszy egzamin maturalny</strong>. Nie daj się zaskoczyć.
    </p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-indigo-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">
      Zacznij przygotowania do polskiego →
    </a>
  </div>
</section>

<script is:inline>
  (function () {
    var target = new Date('2026-05-04T09:00:00').getTime();
    function tick() {
      var diff = Math.max(0, target - Date.now());
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      var el;
      el = document.querySelector('[data-countdown-days]'); if (el) el.textContent = d;
      el = document.querySelector('[data-countdown-hours]'); if (el) el.textContent = h;
      el = document.querySelector('[data-countdown-minutes]'); if (el) el.textContent = m;
      el = document.querySelector('[data-countdown-seconds]'); if (el) el.textContent = s;
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- POPULARNE LEKTURY (TOP 8)                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 text-xs font-semibold mb-4">
        NAJPOPULARNIEJSZE
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Lektury z największą bazą pytań</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">
        Wybierz lekturę i ćwicz dokładnie to, czego potrzebujesz. Każda lektura ma pytania zamknięte, otwarte i tematy na wypracowania.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {topWorks.map((w) => (
        <div class="glass-card p-5 text-center group hover:border-indigo-500/30 transition-all">
          <div class="text-3xl mb-2">📖</div>
          <h3 class="font-display font-bold text-sm mb-1">{w.name}</h3>
          {w.author && <p class="text-xs text-zinc-500 mb-1">{w.author}</p>}
          <p class="text-xs text-indigo-600 dark:text-indigo-400 font-semibold">{w.q} pytań</p>
          <p class="text-[10px] text-zinc-400 mt-1">{w.epoch}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- EPOKI LITERACKIE                                                        -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section id="epoki" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">10 epok literackich — pełny kanon lektur</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">
        Od Starożytności po Współczesność. Każda epoka z pytaniami do wszystkich lektur obowiązkowych — zamknięte, otwarte, wiązki tekstowe i wypracowania.
      </p>
    </div>

    <div class="space-y-4">
      {epochs.map((epoch) => (
        <div class="glass-card p-6 hover:border-indigo-500/20 transition-all">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h3 class="font-display font-bold text-lg">{epoch.name}</h3>
              <span class="text-xs text-zinc-500">{epoch.dateFrom} – {epoch.dateTo}</span>
            </div>
            <span class="text-sm font-semibold text-indigo-600 dark:text-indigo-400">{epoch.works.reduce((s, w) => s + w.q, 0)} pytań</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {epoch.works.map((w) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-zinc-50 dark:bg-surface-800 text-xs font-medium hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors">
                {w.name}
                {w.author && <span class="text-zinc-400">({w.author})</span>}
                <span class="text-indigo-500 font-semibold">{w.q}</span>
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Extra topics -->
    <div class="mt-8 grid md:grid-cols-3 gap-4">
      {extraTopics.map((t) => (
