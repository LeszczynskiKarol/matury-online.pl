---
import Base from '../../../layouts/Base.astro';
import { ThemeToggle } from '../../../components/ui/ThemeToggle';

const topics = [
  { name: 'Biologia komórki', icon: '🔬', questions: 55, subtopics: ['Budowa komórki', 'Organella', 'Błona komórkowa', 'Transport przez błony', 'Oddychanie komórkowe', 'Fotosynteza', 'Podziały komórkowe'] },
  { name: 'Różnorodność organizmów', icon: '🦠', questions: 65, subtopics: ['Klasyfikacja organizmów', 'Bakterie', 'Protisty', 'Grzyby', 'Rośliny', 'Zwierzęta bezkręgowe', 'Zwierzęta kręgowe'] },
  { name: 'Fizjologia człowieka', icon: '🫀', questions: 80, subtopics: ['Układ nerwowy', 'Układ krążenia', 'Układ oddechowy', 'Układ pokarmowy', 'Układ wydalniczy', 'Układ hormonalny', 'Układ odpornościowy', 'Układ ruchu'] },
  { name: 'Genetyka i ewolucja', icon: '🧬', questions: 80, subtopics: ['DNA i RNA', 'Replikacja', 'Transkrypcja i translacja', 'Mutacje', 'Dziedziczenie mendlowskie', 'Krzyżówki genetyczne', 'Genetyka populacji', 'Dobór naturalny'] },
  { name: 'Biologia środowiska', icon: '🌿', questions: 60, subtopics: ['Ekosystem', 'Łańcuchy pokarmowe', 'Obieg materii', 'Przepływ energii', 'Sukcesja ekologiczna', 'Ochrona przyrody', 'Bioróżnorodność'] },
  { name: 'Genetyka i inżynieria genetyczna', icon: '🧪', questions: 0, soon: true, subtopics: ['Inżynieria genetyczna', 'GMO', 'Klonowanie', 'Terapia genowa', 'PCR', 'Elektroforeza'] },
  { name: 'Anatomia i fizjologia człowieka', icon: '🫁', questions: 0, soon: true, subtopics: ['Tkankologia', 'Narządy zmysłów', 'Rozmnażanie', 'Rozwój zarodkowy'] },
  { name: 'Ekologia i ochrona środowiska', icon: '♻️', questions: 0, soon: true, subtopics: ['Zagrożenia środowiska', 'Zanieczyszczenia', 'Zrównoważony rozwój', 'Parki narodowe'] },
  { name: 'Ewolucja i systematyka', icon: '🦎', questions: 0, soon: true, subtopics: ['Dowody ewolucji', 'Mechanizmy ewolucji', 'Specjacja', 'Drzewo filogenetyczne'] },
  { name: 'Botanika', icon: '🌻', questions: 0, soon: true, subtopics: ['Budowa rośliny', 'Tkanki roślinne', 'Rozmnażanie roślin', 'Hormony roślinne'] },
  { name: 'Zoologia', icon: '🐾', questions: 0, soon: true, subtopics: ['Bezkręgowce', 'Kręgowce', 'Przystosowania', 'Zachowania zwierząt'] },
  { name: 'Mikrobiologia i wirusologia', icon: '🦠', questions: 0, soon: true, subtopics: ['Bakterie', 'Wirusy', 'Antybiotyki', 'Szczepionki', 'Odporność'] },
  { name: 'Biotechnologia', icon: '⚗️', questions: 0, soon: true, subtopics: ['Fermentacja', 'Biopaliwa', 'Biofarmaceutyki', 'Diagnostyka molekularna'] },
];

const activeTopics = topics.filter(t => t.questions > 0);
const soonTopics = topics.filter(t => t.questions === 0);
const totalQuestions = topics.reduce((s, t) => s + t.questions, 0); // 340

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o procesy, struktury, zależności biologiczne' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń biologicznych' },
  { icon: '⇄', name: 'Dopasuj pary', desc: 'Połącz struktury z funkcjami, organizmy z cechami' },
  { icon: '↕', name: 'Ustaw kolejność', desc: 'Uporządkuj etapy procesu biologicznego' },
  { icon: '🔬', name: 'Opis schematu', desc: 'Podpisz elementy rysunku biologicznego', badge: 'UNIKALNE' },
  { icon: '🧪', name: 'Projekt doświadczenia', desc: 'Hipoteza, próba kontrolna, zmienna, wniosek', badge: 'UNIKALNE' },
  { icon: '🧬', name: 'Krzyżówka genetyczna', desc: 'Tabela Punnetta z prawdopodobieństwami', badge: 'UNIKALNE' },
  { icon: '🧮', name: 'Obliczenia', desc: 'Stężenia, prawdopodobieństwa, współczynniki', badge: 'AI' },
  { icon: '✎', name: 'Otwarte', desc: 'Wyjaśnij mechanizm, opisz proces — ocena AI', badge: 'AI' },
];

const faq = [
  { q: 'Jakie działy biologii są na maturze 2026?', a: `Matura z biologii obejmuje: biologię komórki, różnorodność organizmów, fizjologię człowieka, genetykę i ewolucję, ekologię i środowisko, botanikę, zoologię, mikrobiologię, biotechnologię. Platforma ma aktualnie ${totalQuestions}+ pytań w 5 głównych działach, a kolejne 8 działów jest w przygotowaniu.` },
  { q: 'Czy matura z biologii jest tylko na poziomie rozszerzonym?', a: 'Tak. Biologia od 2023 roku jest wyłącznie przedmiotem dodatkowym (PR). Egzamin trwa 180 minut, do 60 punktów. Składa się z zadań zamkniętych i otwartych — w tym projektowanie doświadczeń, krzyżówki genetyczne i opisy schematów.' },
  { q: 'Czy platforma ma krzyżówki genetyczne z tabelą Punnetta?', a: 'Tak — to jeden z unikalnych typów zadań. Dostajesz krzyżówkę z genotypami rodziców, wypełniasz tabelę Punnetta i obliczasz prawdopodobieństwo fenotypów potomstwa. AI sprawdza poprawność tabeli, genotypów i obliczeń.' },
  { q: 'Jak działa zadanie "projekt doświadczenia"?', a: 'To format typowy dla matury z biologii: dostajesz problem badawczy, a Twoim zadaniem jest sformułować hipotezę, zaplanować próbę kontrolną i badawczą, wskazać zmienną zależną i niezależną, opisać oczekiwane wyniki. AI ocenia kompletność i poprawność merytoryczną.' },
  { q: 'Ile pytań z biologii jest na platformie?', a: `Aktualnie ${totalQuestions}+ pytań w 5 działach: genetyka i ewolucja (80), fizjologia człowieka (80), różnorodność organizmów (65), biologia środowiska (60), biologia komórki (55). Kolejne 8 działów jest aktywnie rozbudowywanych.` },
  { q: 'Jak przygotować się do matury z biologii w 3 miesiące?', a: '(1) Test diagnostyczny — system znajdzie luki. (2) 30-45 min dziennie — algorytm skupi się na najsłabszych działach. (3) Krzyżówki genetyczne i projekty doświadczeń ćwicz osobno — to najtrudniejsze zadania. (4) Spaced Repetition na definicje i procesy — 10 min dziennie. (5) Ostatni tydzień: pełne arkusze z czasem.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'chemia', name: 'Chemia', icon: '⚗️' },
  { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' }, { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' }, { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---
<Base title="Matura z Biologii 2026 — Genetyka, Fizjologia, Ekologia, Zadania AI | Matury Online">
<!-- NAV -->
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20"><span class="text-white font-display font-bold text-lg">M</span></div><span class="font-display font-bold text-xl hidden sm:block">Matury Online</span></a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#dzialy" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Działy</a>
      <a href="#typy-zadan" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
      <a href="#cennik" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cennik</a>
      <a href="#faq" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-3"><ThemeToggle client:load /><a href="/auth/login" class="btn-ghost text-sm py-2 px-4 hidden sm:inline-flex">Zaloguj się</a><a href="/auth/register" class="btn-primary text-sm py-2 px-5">Rozpocznij naukę</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/10 dark:bg-emerald-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-green-500/10 dark:bg-green-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-emerald-100 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 text-sm font-semibold mb-8">
        <span class="text-2xl">🧬</span> Biologia · PR · {totalQuestions}+ pytań · baza rozbudowywana
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z biologii<br/><span class="bg-gradient-to-r from-emerald-500 to-green-500 bg-clip-text text-transparent">od komórki po ekosystem</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">13 działów</strong> — biologia komórki, genetyka, fizjologia człowieka, ekologia, botanika, zoologia, biotechnologia. Unikalne typy zadań: <strong class="text-zinc-900 dark:text-zinc-100">krzyżówki genetyczne</strong>, <strong class="text-zinc-900 dark:text-zinc-100">projekty doświadczeń</strong>, <strong class="text-zinc-900 dark:text-zinc-100">opisy schematów</strong> — oceniane przez AI.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć biologię — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">13</div><div class="text-sm text-zinc-500 mt-1">działów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">10</div><div class="text-sm text-zinc-500 mt-1">typów zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">AI</div><div class="text-sm text-zinc-500 mt-1">ocena zadań</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-emerald-500 to-green-500">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z biologii — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Biologia to <strong class="text-white">tylko poziom rozszerzony</strong>. Egzamin: 180 minut, do 60 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-emerald-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-14T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- DZIAŁY -->
<section id="dzialy" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">13 działów biologii maturalnej</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">5 działów z pełnymi zestawami pytań, kolejne 8 aktywnie rozbudowywanych. Baza rośnie co tydzień.</p>
    </div>

    <!-- Aktywne działy -->
    <div class="mb-10">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Gotowe — pełne zestawy pytań
      </h3>
      <div class="space-y-4">
        {activeTopics.map((topic) => (
          <div class="glass-card p-6 hover:border-emerald-500/20 transition-all">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <span class="text-2xl">{topic.icon}</span>
                <h4 class="font-display font-bold text-lg">{topic.name}</h4>
              </div>
              <span class="text-sm font-semibold text-emerald-600 dark:text-emerald-400">{topic.questions} pytań</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {topic.subtopics.map((sub) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-xl bg-zinc-50 dark:bg-surface-800 text-xs font-medium hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">{sub}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Działy w przygotowaniu -->
    <div>
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span> W przygotowaniu — pytania dodawane co tydzień
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {soonTopics.map((topic) => (
          <div class="glass-card p-4 text-center opacity-75 hover:opacity-100 transition-all">
            <span class="text-2xl mb-2 block">{topic.icon}</span>
            <h4 class="font-display font-semibold text-xs mb-1">{topic.name}</h4>
            <span class="text-[10px] font-bold text-amber-600 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/30 px-2 py-0.5 rounded-full">wkrótce</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- UNIKALNE TYPY ZADAŃ — highlight -->
<section class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-xs font-semibold mb-4">UNIKALNE NA RYNKU</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">3 typy zadań, których nie znajdziesz nigdzie indziej</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Krzyżówki genetyczne, projekty doświadczeń i opisy schematów — najtrudniejsze formaty na maturze z biologii, zaimplementowane interaktywnie z oceną AI.</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Krzyżówka genetyczna -->
      <div class="glass-card p-6 ring-1 ring-emerald-200 dark:ring-emerald-800/30">
        <div class="text-3xl mb-3">🧬</div>
        <h3 class="font-display font-bold text-lg mb-2">Krzyżówka genetyczna</h3>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">Wypełnij tabelę Punnetta, określ genotypy i fenotypy potomstwa, oblicz prawdopodobieństwa.</p>
        <div class="p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/10">
          <div class="text-xs font-mono text-center mb-2">P: <strong>Aa</strong> × <strong>Aa</strong></div>
          <div class="grid grid-cols-3 gap-1 text-center text-xs max-w-[160px] mx-auto">
            <div></div><div class="font-bold text-emerald-600 p-1">A</div><div class="font-bold text-emerald-600 p-1">a</div>
            <div class="font-bold text-emerald-600 p-1">A</div><div class="bg-white dark:bg-surface-800 rounded p-1 font-mono">AA</div><div class="bg-white dark:bg-surface-800 rounded p-1 font-mono">Aa</div>
            <div class="font-bold text-emerald-600 p-1">a</div><div class="bg-white dark:bg-surface-800 rounded p-1 font-mono">Aa</div><div class="bg-white dark:bg-surface-800 rounded p-1 font-mono">aa</div>
          </div>
          <div class="text-[10px] text-zinc-500 text-center mt-2">Stosunek fenotypowy: 3:1</div>
        </div>
      </div>

      <!-- Projekt doświadczenia -->
      <div class="glass-card p-6 ring-1 ring-emerald-200 dark:ring-emerald-800/30">
        <div class="text-3xl mb-3">🧪</div>
        <h3 class="font-display font-bold text-lg mb-2">Projekt doświadczenia</h3>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">Sformułuj hipotezę, zaplanuj próbę kontrolną i badawczą, wskaż zmienne, opisz wyniki.</p>
        <div class="p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/10 space-y-2">
          <div class="flex items-start gap-2"><span class="text-emerald-500 text-xs font-bold mt-0.5">H</span><span class="text-xs">Hipoteza: Światło wpływa na tempo fotosyntezy</span></div>
          <div class="flex items-start gap-2"><span class="text-blue-500 text-xs font-bold mt-0.5">K</span><span class="text-xs">Próba kontrolna: roślina w ciemności</span></div>
          <div class="flex items-start gap-2"><span class="text-amber-500 text-xs font-bold mt-0.5">B</span><span class="text-xs">Próba badawcza: roślina na świetle</span></div>
          <div class="flex items-start gap-2"><span class="text-red-500 text-xs font-bold mt-0.5">W</span><span class="text-xs">Wniosek: AI ocenia kompletność</span></div>
        </div>
      </div>

      <!-- Opis schematu -->
