---
import Base from '../../../layouts/Base.astro';
import { ThemeToggle } from '../../../components/ui/ThemeToggle';

const topics = [
  { name: 'Kinematyka', icon: '🏃', questions: 34, subtopics: ['Ruch jednostajny', 'Ruch jednostajnie przyspieszony', 'Ruch po okręgu', 'Rzut poziomy', 'Rzut ukośny', 'Wykresy ruchu'] },
  { name: 'Dynamika', icon: '💪', questions: 40, subtopics: ['Zasady dynamiki Newtona', 'Siła tarcia', 'Siła sprężystości', 'Siła dośrodkowa', 'Pęd i zderzenia', 'Zasada zachowania pędu'] },
  { name: 'Grawitacja i astronomia', icon: '🪐', questions: 32, subtopics: ['Prawo powszechnego ciążenia', 'Prędkość kosmiczna', 'Prawa Keplera', 'Natężenie pola grawitacyjnego', 'Energia potencjalna grawitacji'] },
  { name: 'Drgania i fale', icon: '🌊', questions: 37, subtopics: ['Ruch harmoniczny', 'Wahadło matematyczne', 'Fale mechaniczne', 'Dyfrakcja i interferencja', 'Fale stojące', 'Efekt Dopplera', 'Akustyka'] },
  { name: 'Termodynamika', icon: '🌡️', questions: 57, subtopics: ['Temperatura i ciepło', 'Gaz doskonały', 'Przemiany gazowe', 'Zasady termodynamiki', 'Silniki cieplne', 'Ciepło właściwe', 'Przemiany fazowe'] },
  { name: 'Elektrostatyka', icon: '⚡', questions: 32, subtopics: ['Ładunek elektryczny', 'Prawo Coulomba', 'Pole elektryczne', 'Potencjał elektryczny', 'Kondensatory', 'Energia pola elektrycznego'] },
  { name: 'Prąd elektryczny', icon: '🔌', questions: 42, subtopics: ['Natężenie i napięcie', 'Prawo Ohma', 'Obwody elektryczne', 'Łączenie oporników', 'Prawa Kirchhoffa', 'Moc i energia elektryczna'] },
  { name: 'Magnetyzm i indukcja', icon: '🧲', questions: 32, subtopics: ['Pole magnetyczne', 'Siła Lorentza', 'Siła elektrodynamiczna', 'Indukcja elektromagnetyczna', 'Prawo Faradaya', 'Prąd zmienny'] },
  { name: 'Optyka', icon: '🔦', questions: 32, subtopics: ['Odbicie i załamanie', 'Soczewki', 'Zwierciadła', 'Dyfrakcja światła', 'Interferencja światła', 'Polaryzacja'] },
  { name: 'Fizyka atomowa', icon: '⚛️', questions: 30, subtopics: ['Model atomu Bohra', 'Widma atomowe', 'Efekt fotoelektryczny', 'Dualizm korpuskularno-falowy', 'Zasada nieoznaczoności'] },
  { name: 'Fizyka jądrowa', icon: '☢️', questions: 32, subtopics: ['Budowa jądra', 'Promieniotwórczość', 'Rozpad alfa, beta, gamma', 'Okres połowicznego rozpadu', 'Reakcje jądrowe', 'Energia wiązania', 'Fuzja i rozszczepienie'] },
];

const totalQuestions = topics.reduce((s, t) => s + t.questions, 0); // 400

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o prawa, zjawiska, wielkości fizyczne' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń fizycznych' },
  { icon: '📈', name: 'Interpretuj wykres', desc: 'Wykresy ruchu, przemiany gazowe, charakterystyki U(I)' },
  { icon: '▦', name: 'Tabela danych', desc: 'Analiza danych pomiarowych, odczyt z tabeli' },
  { icon: '🧮', name: 'Obliczenia', desc: 'Wynik z jednostką, tolerancją i wzorem — punktacja częściowa', badge: 'AI' },
  { icon: '✗', name: 'Znajdź błąd', desc: 'Wskaż błędny krok w rozumowaniu fizycznym' },
  { icon: '✎', name: 'Otwarte', desc: 'Wyprowadź wzór, wyjaśnij zjawisko — ocena AI', badge: 'AI' },
];

const keyFormulas = [
  { name: 'Droga w ruchu j. przysp.', formula: 's = v₀t + ½at²' },
  { name: 'II zasada Newtona', formula: 'F = ma' },
  { name: 'Prawo Coulomba', formula: 'F = kq₁q₂/r²' },
  { name: 'Prawo Ohma', formula: 'U = IR' },
  { name: 'Energia kinetyczna', formula: 'Eₖ = ½mv²' },
  { name: 'Gaz doskonały', formula: 'pV = nRT' },
  { name: 'Efekt fotoelektryczny', formula: 'Eₖ = hf − W' },
  { name: 'E = mc²', formula: 'E = mc²' },
];

const faq = [
  { q: 'Jakie działy fizyki są na maturze 2026?', a: `Matura z fizyki obejmuje 11 działów: kinematyka, dynamika, grawitacja i astronomia, drgania i fale, termodynamika, elektrostatyka, prąd elektryczny, magnetyzm i indukcja, optyka, fizyka atomowa, fizyka jądrowa. Platforma pokrywa wszystkie — łącznie ${totalQuestions}+ zadań.` },
  { q: 'Czy matura z fizyki jest tylko na poziomie rozszerzonym?', a: 'Tak. Fizyka jest wyłącznie przedmiotem dodatkowym (PR). Egzamin trwa 180 minut, do 60 punktów. Składa się z zadań zamkniętych i otwartych — w tym obliczeniowych z wyprowadzeniem wzorów.' },
  { q: 'Ile pytań z fizyki jest na platformie?', a: `${totalQuestions}+ zadań na 11 działów. Największy zestaw: termodynamika (57), prąd elektryczny (42), dynamika (40), drgania i fale (37). Każdy dział ma zadania zamknięte, obliczeniowe i otwarte.` },
  { q: 'Czy AI potrafi ocenić zadanie obliczeniowe z fizyki?', a: 'Tak. AI sprawdza: wybór wzoru, podstawienie danych, obliczenia pośrednie, wynik z jednostką. Przy błędzie wskazuje dokładny krok i poprawną ścieżkę. Punktacja częściowa — dostajesz punkty za poprawne fragmenty rozwiązania.' },
  { q: 'Jakie wzory muszę znać na maturze z fizyki?', a: 'Na maturze dostajesz zestaw tablic z wzorami i stałymi fizycznymi. Ale szybkość rozwiązywania zależy od tego, ile znasz na pamięć: zasady Newtona, prawo Coulomba, Ohma, wzory na energię, gaz doskonały, efekt fotoelektryczny. Spaced Repetition pomoże je zapamiętać.' },
  
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' }, { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' }, { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---
<Base title="Matura z Fizyki 2026 — Mechanika, Elektryczność, Optyka, Zadania AI | Matury Online">
<!-- NAV -->
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20"><span class="text-white font-display font-bold text-lg">M</span></div><span class="font-display font-bold text-xl hidden sm:block">Matury Online</span></a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#dzialy" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Działy</a>
      <a href="#typy-zadan" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
      <a href="#wzory" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Wzory</a>
      <a href="#cennik" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cennik</a>
      <a href="#faq" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-3"><ThemeToggle client:load /><a href="/auth/login" class="btn-ghost text-sm py-2 px-4 hidden sm:inline-flex">Zaloguj się</a><a href="/auth/register" class="btn-primary text-sm py-2 px-5">Rozpocznij naukę</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-500/10 dark:bg-blue-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-violet-500/10 dark:bg-violet-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-blue-100 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 text-sm font-semibold mb-8">
        <span class="text-2xl">⚛️</span> Fizyka · PR · {totalQuestions}+ zadań
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z fizyki<br/><span class="bg-gradient-to-r from-blue-500 to-violet-500 bg-clip-text text-transparent">od kinematyki po jądro</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">11 działów</strong> — mechanika, termodynamika, elektryczność, magnetyzm, optyka, fizyka atomowa i jądrowa. Zadania obliczeniowe z <strong class="text-zinc-900 dark:text-zinc-100">oceną AI krok po kroku</strong>, wykresy, Spaced Repetition na wzory i stałe fizyczne.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć fizykę — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">11</div><div class="text-sm text-zinc-500 mt-1">działów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">8</div><div class="text-sm text-zinc-500 mt-1">typów zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">AI</div><div class="text-sm text-zinc-500 mt-1">ocena obliczeniowych</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-blue-500 to-violet-500">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z fizyki — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Fizyka to <strong class="text-white">tylko poziom rozszerzony</strong>. Egzamin: 180 minut, do 60 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-blue-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-15T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- DZIAŁY -->
<section id="dzialy" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">11 działów — pełny zakres matury z fizyki</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Mechanika, termodynamika, elektryczność, magnetyzm, optyka, fizyka współczesna — wszystko, co CKE wymaga na rozszerzeniu.</p>
    </div>

    <!-- Mechanika -->
    <div class="mb-8">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">⚙️</span> Mechanika
      </h3>
      <div class="grid md:grid-cols-3 gap-4">
        {topics.slice(0, 3).map(t => (
          <div class="glass-card p-5 hover:border-blue-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Drgania + Termodynamika -->
    <div class="mb-8">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">🌊</span> Drgania, fale i termodynamika
      </h3>
      <div class="grid md:grid-cols-2 gap-4">
        {topics.slice(3, 5).map(t => (
          <div class="glass-card p-5 hover:border-blue-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Elektryczność i magnetyzm -->
    <div class="mb-8">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">⚡</span> Elektryczność i magnetyzm
      </h3>
      <div class="grid md:grid-cols-3 gap-4">
        {topics.slice(5, 8).map(t => (
          <div class="glass-card p-5 hover:border-blue-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Optyka + Fizyka współczesna -->
    <div>
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-sm">⚛️</span> Optyka i fizyka współczesna
      </h3>
      <div class="grid md:grid-cols-3 gap-4">
        {topics.slice(8).map(t => (
          <div class="glass-card p-5 hover:border-blue-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TYPY ZADAŃ -->
<section id="typy-zadan" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Typy zadań maturalnych z fizyki</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Zamknięte, obliczeniowe z wyprowadzeniem, wykresy i analiza danych — jak na arkuszu CKE.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {questionTypes.map(t => (
        <div class="glass-card p-5 relative group hover:border-blue-500/30 transition-all">
          {t.badge && <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-bold bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">{t.badge}</span>}
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{t.icon}</div>
          <h3 class="font-display font-bold text-sm mb-1">{t.name}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AI GRADING DEMO — FIZYKA -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 text-xs font-semibold mb-4">🤖 OCENA AI</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">AI sprawdza zadanie obliczeniowe krok po kroku</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Wybór wzoru, podstawienie, obliczenia, jednostka — punktacja częściowa jak na maturze.</p>
    </div>
