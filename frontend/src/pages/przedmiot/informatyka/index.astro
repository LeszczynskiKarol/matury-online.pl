---
import Base from '../../../layouts/Base.astro';
import { ThemeToggle } from '../../../components/ui/ThemeToggle';

const topics = [
  { name: 'I. Algorytmika i analiza algorytmów', icon: '🔄', questions: 54, subtopics: ['Algorytmy sortowania', 'Algorytmy wyszukiwania', 'Złożoność obliczeniowa', 'Rekurencja', 'Algorytmy zachłanne', 'Pseudokod i schematy blokowe'] },
  { name: 'II. Systemy liczbowe', icon: '🔢', questions: 30, subtopics: ['System binarny', 'System ósemkowy', 'System szesnastkowy', 'Konwersje między systemami', 'Arytmetyka binarna', 'Kodowanie znaków'] },
  { name: 'III. Logika i algebra Boole\'a', icon: '🔲', questions: 24, subtopics: ['Funkcje logiczne', 'Tablice prawdy', 'Bramki logiczne', 'Prawa De Morgana', 'Upraszczanie wyrażeń', 'Algebra Boole\'a'] },
  { name: 'IV. Programowanie', icon: '💻', questions: 45, subtopics: ['Zmienne i typy', 'Instrukcje warunkowe', 'Pętle', 'Funkcje i procedury', 'Tablice', 'Operacje na tekstach', 'Pliki'] },
  { name: 'V. Przetwarzanie danych', icon: '📊', questions: 36, subtopics: ['Formaty danych', 'CSV i JSON', 'Filtrowanie', 'Sortowanie', 'Agregacja', 'Wizualizacja danych'] },
  { name: 'VI. Bazy danych i SQL', icon: '🗄️', questions: 30, subtopics: ['Model relacyjny', 'Klucze główne i obce', 'SELECT i WHERE', 'JOIN', 'GROUP BY i HAVING', 'Funkcje agregujące'] },
  { name: 'VII. Arkusz kalkulacyjny', icon: '📋', questions: 24, subtopics: ['Formuły i funkcje', 'Adresowanie komórek', 'Formatowanie warunkowe', 'Wykresy', 'Tabele przestawne', 'WYSZUKAJ.PIONOWO'] },
  { name: 'VIII. Teoria informatyki', icon: '📖', questions: 30, subtopics: ['Historia informatyki', 'Architektura komputera', 'Sieci komputerowe', 'Protokoły', 'Bezpieczeństwo', 'Prawo autorskie i licencje'] },
  { name: 'IX. Struktury danych', icon: '🌳', questions: 15, subtopics: ['Stosy i kolejki', 'Listy', 'Drzewa', 'Grafy', 'Tablice haszujące'] },
  { name: 'X. Grafika i multimedia', icon: '🎨', questions: 12, subtopics: ['Grafika rastrowa i wektorowa', 'Rozdzielczość', 'Modele barw', 'Kompresja', 'Formaty plików'] },
];

const totalQuestions = topics.reduce((s, t) => s + t.questions, 0); // 300
const topTopics = [...topics].sort((a, b) => b.questions - a.questions).slice(0, 4);

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o algorytmy, systemy, pojęcia informatyczne' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń o sieciach, systemach, algorytmach' },
  { icon: '⎵', name: 'Uzupełnij wynik', desc: 'Wpisz wynik algorytmu, konwersji, zapytania SQL' },
  { icon: '↕', name: 'Ustaw kolejność', desc: 'Uporządkuj kroki algorytmu, etapy przetwarzania' },
  { icon: '📈', name: 'Analiza kodu', desc: 'Odczytaj wynik programu, znajdź wartość zmiennej' },
  { icon: '✗', name: 'Znajdź błąd', desc: 'Wskaż błąd w pseudokodzie lub zapytaniu SQL' },
  { icon: '✎', name: 'Otwarte', desc: 'Napisz algorytm, zapytanie SQL — ocena AI', badge: 'AI' },
];

const faq = [
  { q: 'Jakie działy informatyki są na maturze 2026?', a: `Matura z informatyki obejmuje 10 działów: algorytmika, systemy liczbowe, logika i algebra Boole'a, programowanie, przetwarzanie danych, bazy danych i SQL, arkusz kalkulacyjny, teoria informatyki, struktury danych, grafika i multimedia. Platforma pokrywa wszystkie — łącznie ${totalQuestions}+ pytań.` },
  { q: 'Czy matura z informatyki jest tylko na poziomie rozszerzonym?', a: 'Tak. Informatyka jest wyłącznie przedmiotem dodatkowym (PR). Egzamin składa się z dwóch części: pisemnej (60 min, test + zadania) i praktycznej (150 min, zadania przy komputerze — programowanie + arkusz kalkulacyjny + bazy danych). Łącznie do 80 punktów.' },
  { q: 'Ile pytań z informatyki jest na platformie?', a: `${totalQuestions}+ pytań na 10 działów. Największe zestawy: algorytmika (54), programowanie (45), przetwarzanie danych (36), systemy liczbowe (30), bazy danych i SQL (30), teoria informatyki (30).` },
  { q: 'Jakie języki programowania są na maturze z informatyki?', a: 'Na maturze możesz wybrać: Python, C++, Java lub Pascal. Platforma skupia się na pytaniach algorytmicznych i pseudokodzie — logika jest identyczna niezależnie od języka. Zadania z analizą kodu używają czytelnego pseudokodu.' },
  { q: 'Czy są zadania z SQL?', a: 'Tak. Dział „Bazy danych i SQL" (30 pytań) obejmuje: SELECT, WHERE, JOIN, GROUP BY, HAVING, funkcje agregujące, klucze, relacje. Zadania od prostych zapytań po złożone z wieloma JOINami — jak na części praktycznej matury.' },
  
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' }, { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' },
  { slug: 'historia', name: 'Historia', icon: '🏛️' }, { slug: 'geografia', name: 'Geografia', icon: '🌍' },
];
---
<Base title="Matura z Informatyki 2026 — Algorytmy, Programowanie, SQL, Zadania AI | Matury Online">
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20"><span class="text-white font-display font-bold text-lg">M</span></div><span class="font-display font-bold text-xl hidden sm:block">Matury Online</span></a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#dzialy" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Działy</a>
      <a href="#typy-zadan" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
      <a href="#cennik" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cennik</a>
      <a href="#faq" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-3"><ThemeToggle client:load /><a href="/auth/login" class="btn-ghost text-sm py-2 px-4 hidden sm:inline-flex">Zaloguj się</a><a href="/auth/register" class="btn-primary text-sm py-2 px-5">Rozpocznij naukę</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-teal-500/10 dark:bg-teal-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-emerald-500/10 dark:bg-emerald-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-teal-100 dark:bg-teal-900/20 text-teal-700 dark:text-teal-400 text-sm font-semibold mb-8">
        <span class="text-2xl">💻</span> Informatyka · PR · {totalQuestions}+ pytań
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z informatyki<br/><span class="bg-gradient-to-r from-teal-500 to-emerald-500 bg-clip-text text-transparent">algorytmy, kod, SQL</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">10 działów</strong> — algorytmika, programowanie, bazy danych, arkusz kalkulacyjny, systemy liczbowe, logika Boole'a, struktury danych. Część pisemna z <strong class="text-zinc-900 dark:text-zinc-100">oceną AI</strong> i Spaced Repetition na pojęcia i złożoności.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć informatykę — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">10</div><div class="text-sm text-zinc-500 mt-1">działów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">8</div><div class="text-sm text-zinc-500 mt-1">typów zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">AI</div><div class="text-sm text-zinc-500 mt-1">ocena zadań</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-teal-500 to-emerald-500">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z informatyki — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Informatyka: <strong class="text-white">część pisemna (60 min) + praktyczna (150 min)</strong>. Łącznie do 80 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-teal-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-22T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- TOP TEMATY -->
<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-2xl md:text-3xl mb-3">Kluczowe działy — największe zestawy pytań</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {topTopics.map(t => (
        <div class="glass-card p-5 text-center group hover:border-teal-500/30 transition-all">
          <div class="text-3xl mb-2">{t.icon}</div>
          <div class="font-display font-extrabold text-2xl text-teal-600 dark:text-teal-400 mb-1">{t.questions}</div>
          <h3 class="font-display font-bold text-xs">{t.name}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- DZIAŁY -->
<section id="dzialy" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">10 działów — pełny zakres matury z informatyki</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Algorytmika, programowanie, bazy danych, arkusz, teoria — część pisemna i przygotowanie do praktycznej.</p>
    </div>
    <div class="space-y-4">
      {topics.map(t => (
        <div class="glass-card p-6 hover:border-teal-500/20 transition-all">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{t.icon}</span>
              <h4 class="font-display font-bold text-lg">{t.name}</h4>
            </div>
            <span class="text-sm font-semibold text-teal-600 dark:text-teal-400">{t.questions} pytań</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {t.subtopics.map(s => (
              <span class="px-3 py-1.5 rounded-xl bg-zinc-50 dark:bg-surface-800 text-xs font-medium hover:bg-teal-50 dark:hover:bg-teal-900/20 transition-colors">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TYPY ZADAŃ -->
<section id="typy-zadan" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Typy zadań maturalnych z informatyki</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Analiza kodu, śledzenie algorytmu, zapytania SQL, konwersje — jak na arkuszu CKE.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {questionTypes.map(t => (
        <div class="glass-card p-5 relative group hover:border-teal-500/30 transition-all">
          {t.badge && <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-bold bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400">{t.badge}</span>}
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{t.icon}</div>
          <h3 class="font-display font-bold text-sm mb-1">{t.name}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AI GRADING DEMO -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400 text-xs font-semibold mb-4">🤖 OCENA AI</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">AI sprawdza algorytmy i zapytania SQL</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Analiza pseudokodu, śledzenie zmiennych, poprawność zapytań — z wyjaśnieniem.</p>
    </div>
    <div class="max-w-4xl mx-auto glass-card p-8">
      <div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-700">
        <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Zadanie · Informatyka PR · VI. Bazy danych i SQL</div>
        <p class="font-display text-lg font-semibold">Napisz zapytanie SQL, które wyświetli imiona i nazwiska uczniów, którzy uzyskali średnią ocen powyżej 4.5, posortowanych malejąco po średniej.</p>
        <p class="text-xs text-zinc-500 mt-2">Tabele: <code class="px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 font-mono">uczniowie(id, imie, nazwisko)</code>, <code class="px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 font-mono">oceny(id, uczen_id, ocena)</code></p>
      </div>
      <div class="mb-6 p-4 rounded-2xl bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800/30">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-2">Twoje rozwiązanie</div>
        <pre class="text-sm text-zinc-700 dark:text-zinc-300 font-mono whitespace-pre-wrap">SELECT u.imie, u.nazwisko, AVG(o.ocena) AS srednia
FROM uczniowie u
JOIN oceny o ON u.id = o.uczen_id
GROUP BY u.id, u.imie, u.nazwisko
HAVING AVG(o.ocena) > 4.5
ORDER BY srednia DESC;</pre>
      </div>
      <div class="mb-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Ocena AI</div>
          <div class="flex items-baseline gap-1"><span class="font-display font-extrabold text-3xl text-green-500">4</span><span class="text-zinc-500 text-sm">/ 4 pkt</span></div>
        </div>
        <div class="space-y-2">
          {[
            ['JOIN', 'Poprawne złączenie tabel po kluczu obcym uczen_id'],
            ['GROUP BY', 'Poprawne grupowanie po uczniu (id + imie + nazwisko)'],
            ['HAVING', 'Warunek AVG > 4.5 po agregacji — poprawnie (nie WHERE)'],
            ['ORDER BY', 'Sortowanie malejąco po średniej — zgodne z poleceniem'],
          ].map(([step, detail], i) => (
            <div class="flex items-center gap-3 p-3 rounded-xl bg-green-50 dark:bg-green-900/10">
              <span class="w-6 h-6 rounded-full bg-green-500 text-white text-xs flex items-center justify-center font-bold">✓</span>
              <div class="flex-1"><span class="text-sm font-medium font-mono">{step}</span><span class="text-xs text-zinc-500 ml-2">{detail}</span></div>
              <span class="text-xs font-bold text-green-600">1 pkt</span>
            </div>
          ))}
        </div>
      </div>
      <div class="p-4 rounded-2xl bg-green-50 dark:bg-green-900/10 border border-green-200 dark:border-green-800/30">
        <div class="font-display font-semibold text-sm mb-1">✅ Zapytanie poprawne</div>
        <p class="text-xs text-zinc-600 dark:text-zinc-400">Prawidłowy JOIN, grupowanie, filtrowanie HAVING i sortowanie. Uwaga: w niektórych silnikach SQL wystarczy GROUP BY u.id — ale pełna lista kolumn jest bezpieczniejsza.</p>
      </div>
    </div>
  </div>
</section>

<!-- EGZAMIN — DWIE CZĘŚCI -->
<section class="py-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Matura z informatyki — dwie części</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg">Platforma przygotowuje do części pisemnej. Część praktyczna wymaga ćwiczeń przy komputerze.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
