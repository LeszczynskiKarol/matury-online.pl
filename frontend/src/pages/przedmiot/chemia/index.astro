---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const topicsNieorg = [
  { name: 'Atomy i stechiometria', icon: '⚛️', questions: 32, subtopics: ['Budowa atomu', 'Konfiguracja elektronowa', 'Masa atomowa', 'Mol i masa molowa', 'Obliczenia stechiometryczne', 'Prawo zachowania masy'] },
  { name: 'Budowa atomu i wiązania chemiczne', icon: '🔗', questions: 24, subtopics: ['Wiązanie jonowe', 'Wiązanie kowalencyjne', 'Wiązanie metaliczne', 'Elektroujemność', 'Hybrydyzacja', 'Oddziaływania międzycząsteczkowe'] },
  { name: 'Wiązania chemiczne i oddziaływania', icon: '💎', questions: 32, subtopics: ['Siły van der Waalsa', 'Wiązania wodorowe', 'Polarność cząsteczek', 'Struktura krystaliczna'] },
  { name: 'Systematyka związków nieorganicznych', icon: '🧪', questions: 40, subtopics: ['Tlenki', 'Wodorotlenki', 'Kwasy', 'Sole', 'Nazewnictwo', 'Reakcje otrzymywania'] },
  { name: 'Metale, niemetale i ich związki', icon: '🪙', questions: 32, subtopics: ['Właściwości metali', 'Szereg aktywności', 'Właściwości niemetali', 'Stopy', 'Korozja'] },
  { name: 'Kinetyka i równowaga chemiczna', icon: '⚖️', questions: 40, subtopics: ['Szybkość reakcji', 'Czynniki kinetyczne', 'Równowaga chemiczna', 'Stała równowagi', 'Reguła Le Chateliera'] },
  { name: 'Roztwory, pH, dysocjacja', icon: '🫧', questions: 48, subtopics: ['Stężenie procentowe', 'Stężenie molowe', 'Rozpuszczalność', 'Dysocjacja', 'Skala pH', 'Hydroliza soli', 'Roztwory buforowe'] },
  { name: 'Redoks i elektrochemia', icon: '🔋', questions: 40, subtopics: ['Stopnie utlenienia', 'Bilansowanie redoks', 'Szereg napięciowy', 'Ogniwa galwaniczne', 'Elektroliza', 'Korozja elektrochemiczna'] },
];

const topicsOrg = [
  { name: 'Węglowodory', icon: '🛢️', questions: 35, subtopics: ['Alkany', 'Alkeny', 'Alkiny', 'Węglowodory aromatyczne', 'Izomeria', 'Reakcje substytucji i addycji'] },
  { name: 'Pochodne tlenowe (alkohole, fenole, karbonyle)', icon: '🍷', questions: 24, subtopics: ['Alkohole', 'Fenole', 'Aldehydy', 'Ketony', 'Reakcje utleniania', 'Próba Tollensa i Trommera'] },
  { name: 'Kwasy karboksylowe i estry', icon: '🧴', questions: 18, subtopics: ['Kwasy karboksylowe', 'Estry', 'Estryfikacja', 'Hydroliza estrów', 'Tłuszcze i mydła'] },
  { name: 'Związki azotowe, białka, cukry', icon: '🧬', questions: 12, subtopics: ['Aminy', 'Aminokwasy', 'Wiązanie peptydowe', 'Białka', 'Cukry proste i złożone', 'Polimery'] },
];

const topics = [...topicsNieorg, ...topicsOrg];
const totalQuestions = topics.reduce((s, t) => s + t.questions, 0); // 377

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o reakcje, właściwości, nazewnictwo' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń chemicznych' },
  { icon: '⎵', name: 'Uzupełnij luki', desc: 'Wpisz produkt reakcji, wzór, wartość pH' },
  { icon: '⇄', name: 'Dopasuj pary', desc: 'Połącz substancje z właściwościami, reakcje z typami' },
  { icon: '↕', name: 'Ustaw kolejność', desc: 'Uporządkuj etapy syntezy, szereg aktywności' },
  { icon: '🧮', name: 'Obliczenia', desc: 'Stechiometria, stężenia, pH, entalpia — z jednostką', badge: 'AI' },
  { icon: '✎', name: 'Otwarte', desc: 'Napisz równanie, wyjaśnij mechanizm — ocena AI', badge: 'AI' },
];

const exampleFormulas = [
  { label: 'Reakcja zobojętniania', formula: 'HCl + NaOH → NaCl + H₂O' },
  { label: 'Dysocjacja kwasu', formula: 'H₂SO₄ → 2H⁺ + SO₄²⁻' },
  { label: 'Spalanie metanu', formula: 'CH₄ + 2O₂ → CO₂ + 2H₂O' },
  { label: 'Równanie Hendersona', formula: 'pH = pKₐ + log([A⁻]/[HA])' },
];

const faq = [
  { q: 'Jakie działy chemii są na maturze 2026?', a: `Matura z chemii obejmuje 12 działów: atomy i stechiometria, budowa atomu, wiązania, systematyka nieorganiczna, metale i niemetale, kinetyka, roztwory i pH, redoks i elektrochemia, węglowodory, pochodne tlenowe, kwasy karboksylowe i estry, związki azotowe i biochemia. Platforma pokrywa wszystkie — łącznie ${totalQuestions}+ pytań.` },
  { q: 'Czy matura z chemii jest tylko na poziomie rozszerzonym?', a: 'Tak. Chemia jest wyłącznie przedmiotem dodatkowym (PR). Egzamin trwa 180 minut, do 60 punktów. Zadania: zamknięte, obliczeniowe (stechiometria, pH, stężenia), równania reakcji, wyjaśnienia mechanizmów.' },
  { q: 'Czy wzory chemiczne wyświetlają się poprawnie?', a: 'Tak. Platforma używa KaTeX z rozszerzeniem mhchem — wzory chemiczne, równania reakcji, indeksy stechiometryczne i struktury renderują się profesjonalnie, dokładnie jak w podręczniku. Działa na komputerze i telefonie.' },
  { q: 'Ile pytań z chemii jest na platformie?', a: `${totalQuestions}+ pytań na 12 działów. Największe zestawy: roztwory i pH (48), kinetyka i równowaga (40), systematyka nieorganiczna (40), redoks i elektrochemia (40), węglowodory (35). Baza rozbudowywana regularnie.` },
  { q: 'Czy AI potrafi ocenić zadanie obliczeniowe z chemii?', a: 'Tak. AI sprawdza: zapis równania, obliczenia stechiometryczne, przeliczenia jednostek, wynik końcowy. Przy błędzie wskazuje dokładny krok. Punktacja częściowa — dostajesz punkty za poprawne fragmenty rozwiązania.' },
  
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' }, { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' }, { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---
<Base title="Matura z Chemii 2026 — Organiczna, Stechiometria, pH, Zadania AI | Matury Online">
<!-- NAV -->
<Header navLinks={[
  { href: '#tematy', label: 'Tematy' },
  { href: '#typy-zadan', label: 'Typy zadań' },
  { href: '#cennik', label: 'Cennik' },
  { href: '#faq', label: 'FAQ' },
]} />


<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-purple-500/10 dark:bg-purple-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-fuchsia-500/10 dark:bg-fuchsia-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-purple-100 dark:bg-purple-900/20 text-purple-700 dark:text-purple-400 text-sm font-semibold mb-8">
        <span class="text-2xl">⚗️</span> Chemia · PR · <span data-qcount-min="chemia">{totalQuestions}+</span> pytań
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z chemii<br/><span class="bg-gradient-to-r from-purple-500 to-fuchsia-500 bg-clip-text text-transparent">od atomu po biochemię</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">12 działów</strong> — nieorganiczna i organiczna. Stechiometria, pH, redoks, węglowodory, estry, biochemia. Wzory chemiczne renderowane przez <strong class="text-zinc-900 dark:text-zinc-100">KaTeX + mhchem</strong>, obliczenia oceniane przez AI krok po kroku.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć chemię — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">12</div><div class="text-sm text-zinc-500 mt-1">działów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100" data-qcount-min="chemia">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">8</div><div class="text-sm text-zinc-500 mt-1">typów zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">KaTeX</div><div class="text-sm text-zinc-500 mt-1">wzory chemiczne</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-purple-500 to-fuchsia-500">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z chemii — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">Chemia to <strong class="text-white">tylko poziom rozszerzony</strong>. Egzamin: 180 minut, do 60 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-purple-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-19T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- NOTACJA CHEMICZNA -->
<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 text-xs font-semibold mb-4">⚗️ PROFESJONALNA NOTACJA</div>
      <h2 class="font-display font-bold text-2xl md:text-3xl mb-3">Wzory chemiczne renderowane jak w podręczniku</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">KaTeX z rozszerzeniem mhchem — indeksy, ładunki, strzałki reakcji, struktury. Na komputerze i telefonie.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {exampleFormulas.map(f => (
        <div class="glass-card p-5 text-center hover:border-purple-500/30 transition-all group">
          <div class="font-mono text-base md:text-lg font-bold text-purple-600 dark:text-purple-400 mb-2 group-hover:scale-105 transition-transform">{f.formula}</div>
          <p class="text-xs text-zinc-500">{f.label}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-xs text-zinc-400 mt-4">Na platformie wzory renderowane przez KaTeX — tu uproszczona wersja. W quizie zobaczysz pełną notację z indeksami dolnymi/górnymi i strzałkami.</p>
  </div>
</section>

<!-- DZIAŁY -->
<section id="dzialy" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">12 działów — nieorganiczna i organiczna</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Pełny zakres matury z chemii — od budowy atomu po biochemię.</p>
    </div>

    <!-- Chemia ogólna i nieorganiczna -->
    <div class="mb-10">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-sm">🧪</span>
        Chemia ogólna i nieorganiczna
      </h3>
      <div class="grid md:grid-cols-2 gap-4">
        {topicsNieorg.map(t => (
          <div class="glass-card p-5 hover:border-purple-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-purple-600 dark:text-purple-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Chemia organiczna -->
    <div>
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-sm">🛢️</span>
        Chemia organiczna i biochemia
      </h3>
      <div class="grid md:grid-cols-2 gap-4">
        {topicsOrg.map(t => (
          <div class="glass-card p-5 hover:border-purple-500/20 transition-all">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2"><span class="text-xl">{t.icon}</span><h4 class="font-display font-bold text-sm">{t.name}</h4></div>
              <span class="text-xs font-semibold text-purple-600 dark:text-purple-400">{t.questions}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">{t.subtopics.map(s => <span class="px-2 py-1 rounded-lg bg-zinc-50 dark:bg-surface-800 text-[10px] font-medium">{s}</span>)}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TYPY ZADAŃ -->
<section id="typy-zadan" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Typy zadań maturalnych z chemii</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Równania, obliczenia stechiometryczne, pH, bilansowanie redoks — jak na arkuszu CKE.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {questionTypes.map(t => (
        <div class="glass-card p-5 relative group hover:border-purple-500/30 transition-all">
          {t.badge && <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-bold bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400">{t.badge}</span>}
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{t.icon}</div>
          <h3 class="font-display font-bold text-sm mb-1">{t.name}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AI GRADING DEMO — CHEMIA -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 text-xs font-semibold mb-4">🤖 OCENA AI</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">AI sprawdza obliczenia chemiczne krok po kroku</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Równanie, stechiometria, przeliczenia, wynik z jednostką — punktacja częściowa.</p>
    </div>
    <div class="max-w-4xl mx-auto glass-card p-8">
      <div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-700">
        <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Zadanie obliczeniowe · Chemia PR · Roztwory i pH</div>
        <p class="font-display text-lg font-semibold">Oblicz pH roztworu HCl o stężeniu c = 0,01 mol/dm³. Zakładaj pełną dysocjację.</p>
      </div>
      <div class="mb-6 p-4 rounded-2xl bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800/30">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-2">Twoje rozwiązanie</div>
        <div class="text-sm text-zinc-700 dark:text-zinc-300 space-y-1 font-mono">
          <p>HCl → H⁺ + Cl⁻ (pełna dysocjacja)</p>
          <p>[H⁺] = c = 0,01 mol/dm³ = 10⁻² mol/dm³</p>
          <p>pH = −log[H⁺] = −log(10⁻²) = <strong>2</strong></p>
        </div>
      </div>
      <div class="mb-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Ocena AI</div>
          <div class="flex items-baseline gap-1"><span class="font-display font-extrabold text-3xl text-green-500">3</span><span class="text-zinc-500 text-sm">/ 3 pkt</span></div>
        </div>
        <div class="space-y-2">
          {[
            ['Równanie dysocjacji', 'HCl → H⁺ + Cl⁻ ✓ (kwas mocny, pełna dysocjacja)'],
            ['Stężenie jonów H⁺', '[H⁺] = 0,01 = 10⁻² mol/dm³ ✓'],
            ['Obliczenie pH', 'pH = −log(10⁻²) = 2 ✓'],
          ].map(([step, detail], i) => (
            <div class="flex items-center gap-3 p-3 rounded-xl bg-green-50 dark:bg-green-900/10">
              <span class="w-6 h-6 rounded-full bg-green-500 text-white text-xs flex items-center justify-center font-bold">✓</span>
              <div class="flex-1"><span class="text-sm font-medium">Krok {i+1}: {step}</span><span class="text-xs text-zinc-500 ml-2">{detail}</span></div>
