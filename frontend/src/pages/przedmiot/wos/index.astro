---
import Base from '../../../layouts/Base.astro';
import { ThemeToggle } from '../../../components/ui/ThemeToggle';

const topicsSpoleczenstwo = [
  { name: 'I. Człowiek – koncepcje i aspekty', q: 26 },
  { name: 'II. Dobro wspólne', q: 20 },
  { name: 'III. Społeczność i wspólnoty', q: 23 },
  { name: 'IV. Społeczeństwa i socjalizacja', q: 25 },
  { name: 'V. Różnice społeczne', q: 23 },
  { name: 'VI. Społeczeństwo obywatelskie', q: 27 },
  { name: 'VII. Migracje i demografia', q: 23 },
];

const topicsPolityka = [
  { name: 'VIII. Polityka i kultura polityczna', q: 30 },
  { name: 'IX. Komunikowanie społeczne', q: 20 },
  { name: 'X. Prawo', q: 30 },
  { name: 'XI. Ustrój III RP', q: 38 },
  { name: 'XII. Formy ustroju państw', q: 19 },
];

const topicsWspolczesnosc = [
  { name: 'XIII. Wychodzenie z komunizmu', q: 18 },
  { name: 'XIV. Polityka zagraniczna RP', q: 22 },
  { name: 'XV. Zmiany na świecie po 1989', q: 34 },
];

const allTopics = [...topicsSpoleczenstwo, ...topicsPolityka, ...topicsWspolczesnosc];
const totalQuestions = allTopics.reduce((s, t) => s + t.q, 0); // 378
const topTopics = [...allTopics].sort((a, b) => b.q - a.q).slice(0, 6);

const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Pytania o ustrój, prawo, instytucje, pojęcia' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń o prawie, polityce, społeczeństwie' },
  { icon: '⇄', name: 'Dopasuj pary', desc: 'Połącz instytucje z kompetencjami, pojęcia z definicjami' },
  { icon: '↕', name: 'Ustaw kolejność', desc: 'Uporządkuj procedury prawne, etapy legislacji' },
  { icon: '◫', name: 'Wiązka źródłowa', desc: 'Analiza artykułu Konstytucji, aktu prawnego, wykresu' },
  { icon: '📈', name: 'Analiza danych', desc: 'Wykresy wyborcze, statystyki społeczne, mapy polityczne' },
  { icon: '✎', name: 'Otwarte', desc: 'Oceń zjawisko, porównaj systemy — ocena AI', badge: 'AI' },
];

const faq = [
  { q: 'Jakie działy WOS-u są na maturze 2026?', a: `Matura z WOS obejmuje 15 działów w 3 blokach: społeczeństwo (człowiek, wspólnoty, socjalizacja, różnice, obywatelskość, migracje), polityka i prawo (kultura polityczna, komunikowanie, prawo, ustrój III RP, formy ustrojów), współczesność (transformacja, polityka zagraniczna, zmiany po 1989). Platforma pokrywa wszystkie — łącznie ${totalQuestions}+ pytań.` },
  { q: 'Czy matura z WOS jest tylko na poziomie rozszerzonym?', a: 'Tak. WOS jest wyłącznie przedmiotem dodatkowym (PR). Egzamin: 180 minut, do 60 punktów. Zadania: zamknięte, analiza źródeł (Konstytucja, ustawy, wykresy wyborcze), zadania otwarte.' },
  { q: 'Ile pytań z WOS-u jest na platformie?', a: `${totalQuestions}+ pytań na 15 działów. Największe zestawy: Ustrój III RP (38), Zmiany na świecie po 1989 (34), Polityka i kultura polityczna (30), Prawo (30), Społeczeństwo obywatelskie (27).` },
  { q: 'Jakie źródła pojawiają się na maturze z WOS?', a: 'Artykuły Konstytucji RP, fragmenty ustaw, wykresy wyborcze, statystyki GUS, mapy polityczne, fragmenty przemówień, tabele porównawcze systemów. Platforma ma zadania z analizą tych typów źródeł.' },
  { q: 'Czy AI ocenia zadania otwarte z WOS?', a: 'Tak. AI sprawdza: poprawność merytoryczną, znajomość instytucji i procedur, logikę argumentacji, użycie terminologii prawnej i politologicznej. Wskazuje co poprawić i podaje wzorcową odpowiedź.' },
  
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' }, { slug: 'matematyka', name: 'Matematyka', icon: '📐' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' }, { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' }, { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' },
  { slug: 'historia', name: 'Historia', icon: '🏛️' }, { slug: 'geografia', name: 'Geografia', icon: '🌍' },
];
---
<Base title="Matura z WOS 2026 — Ustrój RP, Prawo, Społeczeństwo, Zadania AI | Matury Online">
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20"><span class="text-white font-display font-bold text-lg">M</span></div><span class="font-display font-bold text-xl hidden sm:block">Matury Online</span></a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#dzialy" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Działy</a>
      <a href="#typy-zadan" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
      <a href="#cennik" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Cennik</a>
      <a href="#faq" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">FAQ</a>
    </div>
    <div class="flex items-center gap-3"><ThemeToggle client:load /><a href="/auth/login" class="btn-ghost text-sm py-2 px-4 hidden sm:inline-flex">Zaloguj się</a><a href="/auth/register" class="btn-primary text-sm py-2 px-5">Rozpocznij naukę</a></div>
  </div>
</nav>

<!-- HERO -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-rose-500/10 dark:bg-rose-500/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-red-500/10 dark:bg-red-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <div class="animate-fade-in"><a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-sm font-medium mb-6 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition">← Wszystkie przedmioty</a></div>
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-rose-100 dark:bg-rose-900/20 text-rose-700 dark:text-rose-400 text-sm font-semibold mb-8">
        <span class="text-2xl">⚖️</span> WOS · PR · {totalQuestions}+ pytań · 15 działów
      </div>
    </div>
    <h1 class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-tight mb-6 animate-slide-up">
      Matura z WOS<br/><span class="bg-gradient-to-r from-rose-500 to-red-600 bg-clip-text text-transparent">ustrój, prawo, społeczeństwo</span>
    </h1>
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 dark:text-zinc-400 mb-10 animate-slide-up" style="animation-delay: 100ms">
      <strong class="text-zinc-900 dark:text-zinc-100">15 działów</strong> w 3 blokach — społeczeństwo, polityka i prawo, współczesność. Analiza Konstytucji, wykresy wyborcze, porównanie ustrojów. Zadania otwarte oceniane przez <strong class="text-zinc-900 dark:text-zinc-100">AI</strong>.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 200ms">
      <a href="/auth/register" class="btn-primary text-base py-4 px-8">Zacznij ćwiczyć WOS — 49 zł/mies.<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 mt-16 animate-fade-in" style="animation-delay: 400ms">
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">15</div><div class="text-sm text-zinc-500 mt-1">działów</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">{totalQuestions}+</div><div class="text-sm text-zinc-500 mt-1">pytań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">8</div><div class="text-sm text-zinc-500 mt-1">typów zadań</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">PR</div><div class="text-sm text-zinc-500 mt-1">rozszerzony</div></div>
      <div class="text-center"><div class="font-display font-extrabold text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100">AI</div><div class="text-sm text-zinc-500 mt-1">ocena otwartych</div></div>
    </div>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="py-12 bg-gradient-to-r from-rose-500 to-red-600">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">⏰ Matura z WOS — maj 2026 (termin rozszerzeń)</p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">Do sesji maturalnej zostało:</h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div></div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6"><div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div><div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div></div>
    </div>
    <p class="text-white/80 text-sm mt-6">WOS to <strong class="text-white">tylko poziom rozszerzony</strong>. Egzamin: 180 minut, do 60 punktów.</p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-rose-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">Zacznij przygotowania →</a>
  </div>
</section>
<script is:inline>
(function(){var t=new Date('2026-05-21T09:00:00').getTime();function k(){var d=Math.max(0,t-Date.now()),D=Math.floor(d/864e5),H=Math.floor(d%864e5/36e5),M=Math.floor(d%36e5/6e4),S=Math.floor(d%6e4/1e3),e;e=document.querySelector('[data-countdown-days]');if(e)e.textContent=D;e=document.querySelector('[data-countdown-hours]');if(e)e.textContent=H;e=document.querySelector('[data-countdown-minutes]');if(e)e.textContent=M;e=document.querySelector('[data-countdown-seconds]');if(e)e.textContent=S}k();setInterval(k,1e3)})();
</script>

<!-- TOP TEMATY -->
<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-2xl md:text-3xl mb-3">Tematy z największą bazą pytań</h2>
      <p class="text-zinc-600 dark:text-zinc-400">Najczęściej pojawiające się na maturze — i u nas najlepiej pokryte.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {topTopics.map(t => (
        <div class="glass-card p-5 text-center group hover:border-rose-500/30 transition-all">
          <div class="font-display font-extrabold text-2xl text-rose-600 dark:text-rose-400 mb-1">{t.q}</div>
          <h3 class="font-display font-bold text-sm">{t.name}</h3>
          <p class="text-[10px] text-zinc-400 mt-1">pytań</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- DZIAŁY -->
<section id="dzialy" class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">15 działów w 3 blokach tematycznych</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Społeczeństwo, polityka i prawo, świat współczesny — pełny zakres matury z WOS.</p>
    </div>

    <!-- Społeczeństwo -->
    <div class="mb-8">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-sm">👥</span>
        Społeczeństwo
        <span class="text-xs text-zinc-400 font-normal ml-2">{topicsSpoleczenstwo.reduce((s, t) => s + t.q, 0)} pytań</span>
      </h3>
      <div class="flex flex-wrap gap-2">
        {topicsSpoleczenstwo.map(t => (
          <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-2xl bg-white dark:bg-surface-800 border border-zinc-200 dark:border-zinc-700 hover:border-rose-400 dark:hover:border-rose-600 transition-all">
            <span class="font-display font-semibold text-sm">{t.name}</span>
            <span class="text-xs font-bold text-rose-600 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/30 px-2 py-0.5 rounded-full">{t.q}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Polityka i prawo -->
    <div class="mb-8">
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-sm">⚖️</span>
        Polityka i prawo
        <span class="text-xs text-zinc-400 font-normal ml-2">{topicsPolityka.reduce((s, t) => s + t.q, 0)} pytań</span>
      </h3>
      <div class="flex flex-wrap gap-2">
        {topicsPolityka.map(t => (
          <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-2xl bg-white dark:bg-surface-800 border border-zinc-200 dark:border-zinc-700 hover:border-rose-400 dark:hover:border-rose-600 transition-all">
            <span class="font-display font-semibold text-sm">{t.name}</span>
            <span class="text-xs font-bold text-rose-600 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/30 px-2 py-0.5 rounded-full">{t.q}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Współczesność -->
    <div>
      <h3 class="font-display font-semibold text-lg mb-4 flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-sm">🌍</span>
        Świat współczesny
        <span class="text-xs text-zinc-400 font-normal ml-2">{topicsWspolczesnosc.reduce((s, t) => s + t.q, 0)} pytań</span>
      </h3>
      <div class="flex flex-wrap gap-2">
        {topicsWspolczesnosc.map(t => (
          <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-2xl bg-white dark:bg-surface-800 border border-zinc-200 dark:border-zinc-700 hover:border-rose-400 dark:hover:border-rose-600 transition-all">
            <span class="font-display font-semibold text-sm">{t.name}</span>
            <span class="text-xs font-bold text-rose-600 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/30 px-2 py-0.5 rounded-full">{t.q}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TYPY ZADAŃ -->
<section id="typy-zadan" class="py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Typy zadań maturalnych z WOS</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Konstytucja, ustawy, wykresy wyborcze, porównanie ustrojów — formaty identyczne z CKE.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {questionTypes.map(t => (
        <div class="glass-card p-5 relative group hover:border-rose-500/30 transition-all">
          {t.badge && <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-[9px] font-bold bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-400">{t.badge}</span>}
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">{t.icon}</div>
          <h3 class="font-display font-bold text-sm mb-1">{t.name}</h3>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AI GRADING DEMO -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-400 text-xs font-semibold mb-4">🤖 OCENA AI</div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">AI ocenia odpowiedzi otwarte z WOS</h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">Sprawdza znajomość instytucji, procedur, terminologii prawnej i politologicznej.</p>
    </div>
    <div class="max-w-4xl mx-auto glass-card p-8">
      <div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-700">
        <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Zadanie otwarte · WOS PR · XI. Ustrój III RP</div>
        <p class="font-display text-lg font-semibold">Wymień dwie kompetencje Trybunału Konstytucyjnego i wyjaśnij, dlaczego jest on istotny dla ochrony praw obywateli.</p>
      </div>
      <div class="mb-6 p-4 rounded-2xl bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800/30">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-2">Twoja odpowiedź</div>
        <p class="text-sm text-zinc-700 dark:text-zinc-300">Trybunał Konstytucyjny: (1) orzeka o zgodności ustaw i umów międzynarodowych z Konstytucją RP; (2) rozpatruje skargi konstytucyjne obywateli. Jest istotny, ponieważ stanowi gwarancję, że władza ustawodawcza nie może uchwalać prawa naruszającego wolności i prawa jednostki zapisane w Konstytucji — obywatel ma bezpośredni instrument ochrony swoich praw.</p>
      </div>
      <div class="mb-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide">Ocena AI</div>
          <div class="flex items-baseline gap-1"><span class="font-display font-extrabold text-3xl text-green-500">3</span><span class="text-zinc-500 text-sm">/ 3 pkt</span></div>
        </div>
        <div class="space-y-2">
          {[
            ['Kompetencja 1', 'Kontrola konstytucyjności ustaw — poprawnie'],
            ['Kompetencja 2', 'Skarga konstytucyjna — poprawnie, trafny wybór'],
            ['Uzasadnienie znaczenia', 'Gwarancja praw jednostki wobec legislatywy — logiczne i kompletne'],
          ].map(([step, detail], i) => (
            <div class="flex items-center gap-3 p-3 rounded-xl bg-green-50 dark:bg-green-900/10">
              <span class="w-6 h-6 rounded-full bg-green-500 text-white text-xs flex items-center justify-center font-bold">✓</span>
              <div class="flex-1"><span class="text-sm font-medium">{step}</span><span class="text-xs text-zinc-500 ml-2">{detail}</span></div>
              <span class="text-xs font-bold text-green-600">1 pkt</span>
            </div>
          ))}
        </div>
      </div>
