<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- AI GRADING DEMO — MATEMATYKA                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="py-20 bg-zinc-50 dark:bg-surface-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-xs font-semibold mb-4">
        🤖 OCENA AI
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">
        AI sprawdza Twoje rozwiązanie krok po kroku — jak nauczyciel
      </h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl mx-auto">
        Zadania otwarte z matematyki oceniane z punktacją częściową. AI wskazuje dokładnie, w którym kroku się pomyliłeś, i pokazuje prawidłową ścieżkę.
      </p>
    </div>

    <div class="max-w-4xl mx-auto glass-card p-8">
      <!-- Treść zadania -->
      <div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-700">
        <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Zadanie otwarte · Matematyka PR · Stereometria</div>
        <p class="font-display text-lg font-semibold">Ostrosłup prawidłowy czworokątny ma krawędź podstawy a = 6 i krawędź boczną l = 5. Oblicz objętość tego ostrosłupa.</p>
      </div>

      <!-- Rozwiązanie ucznia -->
      <div class="mb-6 p-4 rounded-2xl bg-blue-50 dark:bg-blue-900/10 border border-blue-200 dark:border-blue-800/30">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide mb-2">Twoje rozwiązanie</div>
        <div class="text-sm text-zinc-700 dark:text-zinc-300 space-y-1 font-mono">
          <p>Przekątna podstawy: d = a√2 = 6√2</p>
          <p>Połowa przekątnej: d/2 = 3√2</p>
          <p>Wysokość: H = √(l² − (d/2)²) = √(25 − 18) = √7</p>
          <p>Pole podstawy: P = a² = 36</p>
          <p>V = ⅓ · P · H = ⅓ · 36 · √7 = <strong>12√7</strong></p>
        </div>
