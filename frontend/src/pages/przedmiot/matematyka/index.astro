              <span class="text-xs text-zinc-500 ml-2">P = 36 ✓</span>
            </div>
            <span class="text-xs font-bold text-green-600">1 pkt</span>
          </div>
          <div class="flex items-center gap-3 p-3 rounded-xl bg-green-50 dark:bg-green-900/10">
