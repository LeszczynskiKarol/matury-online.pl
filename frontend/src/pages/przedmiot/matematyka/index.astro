---
import Base from '../../../layouts/Base.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';

// ── DANE PRZEDMIOTU ──────────────────────────────────────────────────────
const subject = {
  slug: 'matematyka',
  name: 'Matematyka',
  icon: '📐',
  color: '#f59e0b',
};

// ── DZIAŁY I TEMATY ──────────────────────────────────────────────────────
const topics = [
  {
    name: 'Liczby i algebra',
    icon: '🔢',
    questions: 0,
    subtopics: ['Działania na liczbach', 'Potęgi i pierwiastki', 'Logarytmy', 'Wartość bezwzględna', 'Procenty', 'Ciągi liczbowe', 'Ciąg arytmetyczny', 'Ciąg geometryczny', 'Wyrażenia algebraiczne', 'Równania i nierówności'],
  },
  {
    name: 'Funkcje',
    icon: '📈',
    questions: 0,
    subtopics: ['Pojęcie funkcji', 'Funkcja liniowa', 'Funkcja kwadratowa', 'Funkcja wielomianowa', 'Funkcja wykładnicza', 'Funkcja logarytmiczna', 'Funkcja wymierna', 'Przekształcenia wykresów'],
  },
  {
    name: 'Trygonometria',
    icon: '📐',
    questions: 0,
    subtopics: ['Funkcje trygonometryczne', 'Miara łukowa', 'Wzory redukcyjne', 'Tożsamości trygonometryczne', 'Równania trygonometryczne', 'Twierdzenie sinusów', 'Twierdzenie cosinusów'],
  },
  {
    name: 'Planimetria',
    icon: '📏',
    questions: 0,
    subtopics: ['Trójkąty', 'Czworokąty', 'Wielokąty foremne', 'Okręgi i koła', 'Pole i obwód', 'Podobieństwo figur', 'Twierdzenie Pitagorasa', 'Twierdzenie Talesa'],
  },
  {
    name: 'Geometria analityczna',
    icon: '🎯',
    questions: 0,
    subtopics: ['Układ współrzędnych', 'Prosta na płaszczyźnie', 'Równanie okręgu', 'Odległość punktów', 'Wektor', 'Symetrie'],
  },
  {
    name: 'Stereometria',
    icon: '🧊',
    questions: 0,
    subtopics: ['Graniastosłupy', 'Ostrosłupy', 'Walec', 'Stożek', 'Kula', 'Objętość i pole powierzchni', 'Przekroje brył'],
  },
  {
    name: 'Kombinatoryka i prawdopodobieństwo',
    icon: '🎲',
    questions: 0,
    subtopics: ['Permutacje', 'Kombinacje', 'Wariacje', 'Symbol Newtona', 'Prawdopodobieństwo klasyczne', 'Prawdopodobieństwo warunkowe', 'Schemat Bernoulliego'],
  },
  {
    name: 'Statystyka i analiza danych',
    icon: '📊',
    questions: 0,
    subtopics: ['Średnia arytmetyczna', 'Mediana', 'Odchylenie standardowe', 'Wariancja', 'Kwartyle', 'Diagramy i wykresy'],
  },
  {
    name: 'Rachunek różniczkowy (PR)',
    icon: '∫',
    questions: 0,
    subtopics: ['Pochodna funkcji', 'Reguły różniczkowania', 'Ekstrema funkcji', 'Monotoniczność', 'Styczna do wykresu'],
  },
];

const totalQuestions = 500;

// ── KLUCZOWE WZORY ───────────────────────────────────────────────────────
const keyFormulas = [
  { name: 'Wzór skróconego mnożenia', formula: '(a ± b)² = a² ± 2ab + b²' },
  { name: 'Wyróżnik trójmianu', formula: 'Δ = b² − 4ac' },
  { name: 'Wzory Viète\'a', formula: 'x₁ + x₂ = −b/a, x₁·x₂ = c/a' },
  { name: 'Twierdzenie Pitagorasa', formula: 'a² + b² = c²' },
  { name: 'Pole trójkąta', formula: 'P = ½ah = ½ab sin γ' },
  { name: 'Tw. sinusów', formula: 'a/sin α = b/sin β = 2R' },
  { name: 'Tw. cosinusów', formula: 'c² = a² + b² − 2ab cos γ' },
  { name: 'Objętość kuli', formula: 'V = ⁴⁄₃πr³' },
];

// ── TYPY ZADAŃ DLA MATEMATYKI ────────────────────────────────────────────
const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D', desc: 'Klasyczne pytania jednokrotnego wyboru — 1 punkt każde' },
  { icon: '☑', name: 'Wielokrotne', desc: 'Wskaż wszystkie poprawne odpowiedzi z listy' },
  { icon: '⚖', name: 'Prawda / Fałsz', desc: 'Oceń prawdziwość stwierdzeń matematycznych' },
  { icon: '⎵', name: 'Uzupełnij wynik', desc: 'Wpisz obliczony wynik — akceptowana tolerancja błędu' },
  { icon: '📈', name: 'Interpretuj wykres', desc: 'Odczytaj dane z wykresu funkcji lub diagramu' },
  { icon: '▦', name: 'Tabela danych', desc: 'Analiza i obliczenia na danych tabelarycznych' },
  { icon: '✗', name: 'Znajdź błąd', desc: 'Wskaż błędny krok w rozumowaniu matematycznym' },
  { icon: '∴', name: 'Ułóż dowód', desc: 'Uporządkuj kroki dowodu — od założeń do tezy' },
  { icon: '🧮', name: 'Obliczenia', desc: 'Wynik z jednostką, tolerancją i punktacją częściową', badge: 'AI' },
  { icon: '✎', name: 'Otwarte (rozszerzone)', desc: 'Zadania z pełnym rozwiązaniem — ocena AI krok po kroku', badge: 'AI' },
];

// ── FAQ ──────────────────────────────────────────────────────────────────
const faq = [
  {
    q: 'Jakie działy matematyki są na maturze 2026?',
    a: 'Matura 2026 z matematyki obejmuje: liczby i algebra, funkcje (liniowa, kwadratowa, wykładnicza, logarytmiczna), trygonometria, planimetria, geometria analityczna, stereometria, kombinatoryka i prawdopodobieństwo, statystyka. Na poziomie rozszerzonym dochodzi rachunek różniczkowy (pochodne, ekstrema, monotoniczność). Platforma pokrywa wszystkie te działy.',
  },
  {
    q: 'Czym różni się matura podstawowa (PP) od rozszerzonej (PR) z matematyki?',
    a: 'PP to 35 zadań (28 zamkniętych + 7 otwartych) w 180 minut, max 50 punktów — próg zdania 30%. PR to 13 zadań otwartych w 180 minut, max 50 punktów — tutaj nie ma progu, liczy się wynik do rekrutacji. PR wymaga pochodnych, dowodów, trudniejszej stereometrii i głębszej algebry. Na platformie filtrujesz PP, PR lub mix.',
  },
  {
    q: 'Ile pytań z matematyki jest na platformie?',
    a: `Aktualnie mamy ${totalQuestions}+ pytań z matematyki, obejmujących wszystkie działy PP i PR. Pytania odpowiadają formatom CKE — zamknięte, otwarte z pełnym rozwiązaniem, interpretacja wykresów, obliczenia z tolerancją. Baza jest regularnie rozbudowywana o nowe zestawy.`,
  },
  {
    q: 'Czy AI potrafi ocenić zadanie otwarte z matematyki?',
    a: 'Tak. AI analizuje Twoje rozwiązanie krok po kroku — sprawdza poprawność metody, obliczeń pośrednich i wyniku końcowego. Przy błędzie wskazuje dokładnie, w którym kroku się pomyliłeś, i pokazuje prawidłowe rozwiązanie. Punktacja częściowa działa tak samo jak na prawdziwej maturze — dostajesz punkty za poprawne fragmenty rozumowania.',
  },
  {
    q: 'Jakie wzory muszę znać na pamięć na maturze z matematyki?',
    a: 'Na maturze dostajesz tablice z podstawowymi wzorami, ale warto znać na pamięć: wzory skróconego mnożenia, wyróżnik trójmianu kwadratowego, wzory Viète\'a, twierdzenie Pitagorasa, twierdzenia sinusów i cosinusów, wzory na pola i objętości brył. Platforma pomaga je zapamiętać przez Spaced Repetition — wzory wracają w optymalnych odstępach.',
  },
  
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// ── INNE PRZEDMIOTY ──────────────────────────────────────────────────────
const otherSubjects = [
  { slug: 'polski', name: 'Polski', icon: '📚' },
  { slug: 'angielski', name: 'Angielski', icon: '🇬🇧' },
  { slug: 'biologia', name: 'Biologia', icon: '🧬' },
  { slug: 'chemia', name: 'Chemia', icon: '⚗️' },
  { slug: 'fizyka', name: 'Fizyka', icon: '⚛️' },
  { slug: 'historia', name: 'Historia', icon: '🏛️' },
  { slug: 'geografia', name: 'Geografia', icon: '🌍' },
  { slug: 'wos', name: 'WOS', icon: '⚖️' },
];
---

<Base title="Matura z Matematyki 2026 — Zadania, Wzory, Rozwiązania AI | Matury Online">

