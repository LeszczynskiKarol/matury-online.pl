<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- COUNTDOWN DO MATURY 2026                                                -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section class="py-12 bg-gradient-to-r from-brand-500 to-navy-600">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-3">
      ⏰ Matura polski — poniedziałek, 4 maja 2026, godz. 9:00
    </p>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-white mb-6">
      Do matury 2026 zostało:
    </h2>
    <div class="grid grid-cols-4 gap-3 md:gap-6 max-w-2xl mx-auto">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-days>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">dni</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-hours>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">godzin</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-minutes>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">minut</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-6">
        <div class="font-display font-extrabold text-3xl md:text-5xl text-white tabular-nums" data-countdown-seconds>--</div>
        <div class="text-white/70 text-[10px] md:text-xs uppercase tracking-wide mt-1">sekund</div>
      </div>
    </div>
    <p class="text-white/80 text-sm mt-6">
      Jeszcze możesz nadrobić zaległości. Średni wzrost wyniku po 30 dniach regularnej nauki: <strong class="text-white">+18 punktów procentowych</strong>.
    </p>
    <a href="/auth/register" class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-2xl bg-white text-navy-600 font-display font-semibold text-sm hover:bg-white/90 transition-all">
      Zacznij dziś — odliczanie działa na Twoją korzyść →
    </a>
  </div>
</section>

<script is:inline>
  (function () {
    const maturaDates = [
      new Date('2026-05-04T09:00:00').getTime(),
      new Date('2027-05-03T09:00:00').getTime(),
    ];
    function tick() {
      const now = Date.now();
      const target = maturaDates.find(d => d > now) || maturaDates[maturaDates.length - 1];
      const diff = Math.max(0, target - now);
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      document.querySelector('[data-countdown-days]').textContent = d;
      document.querySelector('[data-countdown-hours]').textContent = h;
      document.querySelector('[data-countdown-minutes]').textContent = m;
      document.querySelector('[data-countdown-seconds]').textContent = s;
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

