---
import Base from '../layouts/Base.astro';
import { ThemeToggle } from '../components/ui/ThemeToggle';

// ── PRZEDMIOTY (10 popularnych maturalnych) ────────────────────────────────
const subjects = [
  { slug: 'polski',      name: 'Język polski',    short: 'Polski',      icon: '📚', color: '#6366f1', questions: 500, topics: 'Epoki · Lektury · Rozprawka · Interpretacja', level: 'PP + PR' },
  { slug: 'matematyka',  name: 'Matematyka',      short: 'Matematyka',  icon: '📐', color: '#f59e0b', questions: 500, topics: 'Funkcje · Geometria · Trygonometria · Stereometria', level: 'PP + PR' },
  { slug: 'angielski',   name: 'Język angielski', short: 'Angielski',   icon: '🇬🇧', color: '#ef4444', questions: 500, topics: 'Słuchanie AI · Gramatyka · Słownictwo · Pisanie', level: 'PP + PR' },
  { slug: 'biologia',    name: 'Biologia',        short: 'Biologia',    icon: '🧬', color: '#22c55e', questions: 500, topics: 'Genetyka · Ekologia · Fizjologia · Ewolucja', level: 'PP + PR' },
  { slug: 'chemia',      name: 'Chemia',          short: 'Chemia',      icon: '⚗️', color: '#a855f7', questions: 500, topics: 'Organiczna · Stechiometria · Reakcje · Obliczenia', level: 'PP + PR' },
  { slug: 'fizyka',      name: 'Fizyka',          short: 'Fizyka',      icon: '⚛️', color: '#3b82f6', questions: 500, topics: 'Mechanika · Elektryczność · Termodynamika · Optyka', level: 'PP + PR' },
  { slug: 'historia',    name: 'Historia',        short: 'Historia',    icon: '🏛️', color: '#78716c', questions: 500, topics: 'Starożytność · Średniowiecze · Nowożytność · XX wiek', level: 'PP + PR' },
  { slug: 'geografia',   name: 'Geografia',       short: 'Geografia',   icon: '🌍', color: '#0ea5e9', questions: 500, topics: 'Fizyczna · Ekonomiczna · Mapy · Klimat', level: 'PP + PR' },
  { slug: 'wos',         name: 'WOS',             short: 'WOS',         icon: '⚖️', color: '#dc2626', questions: 500, topics: 'Ustrój RP · UE · Prawo · Polityka', level: 'PP + PR' },
  { slug: 'informatyka', name: 'Informatyka',     short: 'Informatyka', icon: '💻', color: '#059669', questions: 500, topics: 'Algorytmy · Programowanie · Bazy danych · Sieci', level: 'PP + PR' },
];

// ── 19 TYPÓW ZADAŃ (pokazujemy "15+") ──────────────────────────────────────
const questionTypes = [
  { icon: '◉', name: 'Zamknięte A–D',    desc: 'Klasyczne pytania jednokrotnego wyboru',       slug: 'zamkniete' },
  { icon: '☑', name: 'Wielokrotne',      desc: 'Wybór kilku poprawnych odpowiedzi',            slug: 'wielokrotne' },
  { icon: '⚖', name: 'Prawda / Fałsz',   desc: 'Ocena prawdziwości stwierdzeń',                slug: 'prawda-falsz' },
  { icon: '✎', name: 'Otwarte',          desc: 'Krótkie odpowiedzi oceniane przez AI',         slug: 'otwarte', badge: 'AI' },
  { icon: '📄', name: 'Wypracowania',    desc: 'Rozprawka, interpretacja — AI według CKE',     slug: 'wypracowania', badge: 'AI' },
  { icon: '⎵', name: 'Uzupełnij luki',   desc: 'Wpisz brakujące słowa lub liczby',             slug: 'uzupelnij' },
  { icon: '⇄', name: 'Dopasuj pary',     desc: 'Połącz elementy z dwóch kolumn',               slug: 'dopasuj' },
  { icon: '↕', name: 'Ustaw kolejność',  desc: 'Uporządkuj chronologicznie lub logicznie',     slug: 'kolejnosc' },
  { icon: '◫', name: 'Wiązka tekstu',    desc: 'Analiza fragmentu z pytaniami mieszanymi',     slug: 'wiazka' },
  { icon: '✗', name: 'Znajdź błąd',      desc: 'Wskaż błędny krok w rozumowaniu',              slug: 'blad' },
  { icon: '📈', name: 'Interpretuj wykres', desc: 'Odczytaj dane z grafu lub diagramu',        slug: 'wykres' },
  { icon: '▦', name: 'Tabela danych',    desc: 'Analiza danych tabelarycznych',                slug: 'tabela' },
  { icon: '∴', name: 'Ułóż dowód',       desc: 'Uporządkuj kroki dowodu matematycznego',       slug: 'dowod' },
  { icon: '⎽', name: 'Luki w tekście',   desc: 'Uzupełnij brakujące fragmenty tekstu',         slug: 'luki' },
  { icon: '🎧', name: 'Słuchanie AI',    desc: 'Nagrania generowane na żywo przez AI',         slug: 'sluchanie', badge: 'AI LIVE' },
  { icon: '🔬', name: 'Opis schematu',   desc: 'Podpisz elementy rysunku biologicznego',       slug: 'schemat' },
  { icon: '🧪', name: 'Projekt doświadczenia', desc: 'Zaprojektuj hipotezę i próbę kontrolną', slug: 'doswiadczenie' },
  { icon: '🧬', name: 'Krzyżówka genetyczna', desc: 'Tabela Punnetta z prawdopodobieństwami',  slug: 'krzyzowka' },
  { icon: '🧮', name: 'Obliczenia',      desc: 'Wynik z jednostką i tolerancją błędu',         slug: 'obliczenia' },
];

// ── FUNKCJE PLATFORMY ──────────────────────────────────────────────────────
const features = [
  { icon: '🤖', title: 'AI ocenia wypracowania jak egzaminator CKE', desc: 'Claude Sonnet sprawdza Twoje prace w 30 sekund — punkty po kryteriach CKE, mocne strony, konkretne wskazówki do poprawy.' },
  { icon: '🎯', title: 'Adaptacyjna trudność', desc: 'System Elo utrzymuje 70% skuteczności — zawsze uczysz się w strefie rozwoju. Nie za łatwo, nie za trudno.' },
  { icon: '🧠', title: 'Spaced Repetition (SM-2)', desc: 'Ten sam algorytm, z którego korzysta Anki i studenci medycyny. Pytania wracają w optymalnym momencie.' },
  { icon: '🎧', title: 'Nieograniczone słuchanie angielskiego', desc: 'AI generuje świeże nagrania na żywo — brytyjskie, amerykańskie, australijskie akcenty. Każda sesja inna.' },
  { icon: '📊', title: 'Szczegółowe statystyki i dashboard', desc: 'Heatmapa aktywności, poziomy per przedmiot, XP, streaki. Widzisz dokładnie gdzie jesteś i co poprawić.' },
  { icon: '🏆', title: 'Gamifikacja w stylu Duolingo', desc: 'Punkty XP, poziomy, streaki, osiągnięcia. Nauka staje się nawykiem, a nie karą.' },
];

// ── FAQ ROZBUDOWANE (pod SEO long-tail) ────────────────────────────────────
const faq = [
  { q: 'Ile kosztuje platforma matury-online.pl w 2026 roku?',
    a: 'Subskrypcja kosztuje 49 zł miesięcznie i daje pełny dostęp do wszystkich przedmiotów, typów zadań i funkcji AI. Alternatywnie jednorazowa płatność 59 zł daje 30 dni dostępu bez subskrypcji. Oba warianty odblokowują dokładnie to samo — 10 przedmiotów maturalnych, 5000+ pytań, AI ocena wypracowań, słuchanie angielskiego generowane na żywo, Spaced Repetition i pełne statystyki.' },
  { q: 'Jakie przedmioty maturalne są dostępne na platformie?',
    a: 'Obsługujemy wszystkie popularne przedmioty maturalne: język polski, matematykę, język angielski, biologię, chemię, fizykę, historię, geografię, WOS (wiedzę o społeczeństwie) i informatykę. Każdy przedmiot ma poziom podstawowy (PP) i rozszerzony (PR), minimum 500 pytań autorskich, zgodnych z podstawą programową CKE.' },
  { q: 'Czy AI naprawdę potrafi ocenić wypracowanie maturalne?',
    a: 'Tak. Wykorzystujemy Claude Sonnet od Anthropic skonfigurowany pod oficjalne kryteria CKE dla każdego przedmiotu. Dla wypracowania z polskiego AI ocenia 6 kryteriów (realizacja tematu, teza i argumentacja, kompozycja, styl, język, zapis) do łącznie 36 punktów — identycznie jak egzaminator. AI zawsze wskazuje mocne strony, konkretne błędy i co poprawić.' },
  { q: 'Jak działa generowane na żywo słuchanie z angielskiego?',
    a: 'To flagowa funkcja niedostępna nigdzie indziej na polskim rynku. Za każdym razem, gdy prosisz o kolejne zadanie ze słuchania, AI generuje nowy transkrypt (dialog, monolog, wywiad, podcast), a następnie Google Text-to-Speech syntezuje głos w akcencie brytyjskim, amerykańskim lub australijskim z różnymi lektorami. Otrzymujesz 2 odtworzenia zgodnie z CKE i pytania typu CLOSED, TRUE/FALSE, FILL_IN. Poziomy B1+ (matura podstawowa) do C1 (rozszerzona).' },
  { q: 'Kiedy jest matura 2026 i ile zostało dni?',
    a: 'Matura 2026 rozpoczyna się 4 maja 2026 (poniedziałek) egzaminem z języka polskiego na poziomie podstawowym. Następne dni to matematyka (5 maja) i języki obce (6-7 maja). Egzaminy rozszerzone odbywają się w drugiej połowie miesiąca. Licznik na naszej stronie pokazuje dokładnie ile dni, godzin i minut zostało.' },
  { q: 'Czy można zdać maturę bez korepetycji, tylko z matury-online.pl?',
    a: 'Zdecydowanie tak — platforma jest zaprojektowana jako kompletny substytut korepetycji. Adaptacyjny system trudności pełni rolę nauczyciela, który dobiera zadania pod Twój poziom. AI ocenia wypracowania tak, jak robiłby to prywatny egzaminator. Spaced Repetition pilnuje powtórek. Koszt 49 zł miesięcznie vs 400-600 zł za 4 godziny korepetycji tygodniowo to oszczędność ponad 8000 zł rocznie.' },
  { q: 'Jak przygotować się do matury w 2-3 miesiące?',
    a: 'Plan intensywny: (1) Test diagnostyczny na początku — identyfikuje luki. (2) 30-45 minut dziennie z platformy — adaptacyjny algorytm automatycznie skupi się na słabych tematach. (3) Jedno wypracowanie tygodniowo per przedmiot rozszerzony — AI ocena pokaże co poprawiać. (4) Codzienne powtórki Spaced Repetition — 10 minut. (5) Ostatni tydzień — pełne arkusze maturalne w trybie exam simulation.' },
  { q: 'Czym różni się matura podstawowa (PP) od rozszerzonej (PR)?',
    a: 'Podstawowa jest wymagana do zdania matury (30% próg), rozszerzona liczy się do rekrutacji na studia. PP obejmuje poziom szkoły średniej, PR wykracza poza program (materiał uzupełniający, trudniejsze obliczenia, głębsza analiza). Na platformie każdy przedmiot ma filtry pozwalające uczyć się tylko PP, tylko PR albo mix. Zadania są odpowiednio oznaczone.' },
  { q: 'Jakie są typy zadań na prawdziwej maturze i czy platforma je pokrywa?',
    a: 'Platforma obsługuje 19 typów zadań — więcej niż pojawia się na prawdziwej maturze: zamknięte A-D, wielokrotnego wyboru, prawda/fałsz, luki, dopasowania, porządkowanie, pytania otwarte, wypracowania, wiązki tekstu, interpretacja wykresów i tabel, znajdź błąd, krzyżówki genetyczne, projektowanie doświadczeń, obliczenia chemiczne i fizyczne, a dla angielskiego — słuchanie z nagraniami AI.' },
  { q: 'Czy mogę wybrać konkretną lekturę lub dział do nauki?',
    a: 'Tak. Dla polskiego masz zestawy pytań per lektura (Pan Tadeusz, Dziady III, Lalka, Wesele, Ferdydurke, Dżuma i dziesiątki innych). Dla matematyki filtry per dział (funkcje, stereometria, prawdopodobieństwo). Dla biologii per zagadnienie (genetyka, cytologia, fizjologia). Możesz też mieszać tematy lub losować ze wszystkich.' },
  { q: 'Czy platforma działa na telefonie?',
    a: 'Tak, w pełni responsywna — wszystkie funkcje działają w przeglądarce mobilnej, z trybem ciemnym, pełną synchronizacją między urządzeniami. Nie potrzebujesz aplikacji ze sklepu.' },
  { q: 'Czy mogę anulować subskrypcję w dowolnym momencie?',
    a: 'Tak. Anulowanie jednym kliknięciem w panelu użytkownika. Zachowujesz pełny dostęp do końca opłaconego okresu rozliczeniowego — nie tracisz pieniędzy. Możesz również wznowić anulowaną subskrypcję, zanim wygaśnie.' },
  { q: 'Jakie metody płatności są akceptowane?',
    a: 'Wszystkie popularne w Polsce: karta (Visa, Mastercard), BLIK, Revolut Pay. Dla subskrypcji — karta lub Revolut Pay (automatyczne odnowienie). Dla jednorazowej płatności 59 zł — karta, BLIK lub Revolut Pay. Płatności obsługuje Stripe z szyfrowaniem na poziomie bankowym.' },
];

// ── JSON-LD dla FAQ (rich snippets w Google) ──────────────────────────────
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Matura Online — Platforma przygotowania do matury 2026',
  description: 'Kompletna platforma do nauki przed maturą z AI. 10 przedmiotów, 5000+ pytań, 19 typów zadań, ocena wypracowań przez AI, generowane na żywo słuchanie angielskiego.',
  brand: { '@type': 'Brand', name: 'Matury Online' },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'PLN',
    lowPrice: '49',
    highPrice: '59',
    offerCount: 2,
  },
};
---

<Base title="Matura Online 2026 — Testy i Sprawdziany Maturalne — Przygotowanie do Matury">

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- NAV                                                                      -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<nav class="fixed top-0 w-full z-50 border-b border-zinc-200/50 dark:border-zinc-800/50 bg-white/80 dark:bg-surface-950/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20">
        <span class="text-white font-display font-bold text-lg">M</span>
      </div>
      <span class="font-display font-bold text-xl hidden sm:block">Matury Online</span>
    </a>
    <div class="hidden md:flex items-center gap-7">
      <a href="#przedmioty" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Przedmioty</a>
      <a href="#zadania" class="text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition">Typy zadań</a>
