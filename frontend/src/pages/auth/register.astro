---
import Base from '../../layouts/Base.astro';
import { ThemeToggle } from '../../components/ui/ThemeToggle';
const siteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
---

<Base title="Załóż konto — Matury Online" noindex={true}>
  <div class="fixed top-4 right-4 z-50"><ThemeToggle client:load /></div>
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-brand-500/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20">
            <span class="text-white font-display font-bold text-lg">M</span>
          </div>
          <span class="font-display font-bold text-xl">Matury Online</span>
        </a>
        <h1 class="font-display font-bold text-2xl mb-2">Zacznij za darmo</h1>
        <p class="text-zinc-500 text-sm">Stwórz konto i zacznij naukę w 30 sekund</p>
      </div>

      <div class="glass-card p-8">
        <!-- Google -->
        <div class="flex justify-center mb-6">
          <div id="g_id_onload" data-client_id={googleClientId} data-callback="handleGoogleCredential" data-auto_prompt="false"></div>
          <div class="g_id_signin" data-type="standard" data-shape="rectangular" data-theme="outline" data-text="signup_with" data-size="large" data-locale="pl" data-width="350"></div>
        </div>

        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-zinc-200 dark:bg-zinc-700"></div>
          <span class="text-xs text-zinc-400">lub email</span>
          <div class="flex-1 h-px bg-zinc-200 dark:bg-zinc-700"></div>
        </div>

        <form id="register-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium mb-1.5">Imię</label>
            <input type="text" id="name" class="input" placeholder="Twoje imię" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1.5">Email</label>
            <input type="email" id="email" required class="input" placeholder="twoj@email.pl" />
          </div>

          <!-- Password with eye toggle + strength -->
          <div>
            <label for="password" class="block text-sm font-medium mb-1.5">Hasło</label>
            <div class="relative">
              <input type="password" id="password" required minlength="8" class="input pr-11" placeholder="Min. 8 znaków" />
              <button type="button" class="eye-toggle absolute right-3 top-1/2 -translate-y-1/2 p-1 text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300" data-target="password">
                <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
              </button>
            </div>
            <!-- Strength indicator -->
            <div id="strength-bar" class="mt-2 space-y-1.5 hidden">
              <div class="flex gap-1">
                <div class="strength-segment h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="strength-segment h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="strength-segment h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="strength-segment h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="strength-segment h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
              </div>
              <div id="strength-checks" class="flex flex-wrap gap-x-3 gap-y-0.5 text-[11px]">
                <span data-check="length" class="text-zinc-400">✗ 8+ znaków</span>
                <span data-check="lower" class="text-zinc-400">✗ mała litera</span>
                <span data-check="upper" class="text-zinc-400">✗ wielka litera</span>
                <span data-check="digit" class="text-zinc-400">✗ cyfra</span>
                <span data-check="special" class="text-zinc-400">✗ znak specjalny</span>
              </div>
            </div>
          </div>

          <!-- Confirm password -->
          <div>
            <label for="passwordConfirm" class="block text-sm font-medium mb-1.5">Powtórz hasło</label>
            <div class="relative">
              <input type="password" id="passwordConfirm" required class="input pr-11" placeholder="Powtórz hasło" />
              <button type="button" class="eye-toggle absolute right-3 top-1/2 -translate-y-1/2 p-1 text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300" data-target="passwordConfirm">
                <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
              </button>
            </div>
            <p id="match-msg" class="text-[11px] mt-1 hidden"></p>
          </div>

          <!-- Terms -->
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="acceptTerms" required class="mt-0.5 w-4 h-4 rounded border-zinc-300 dark:border-zinc-600 text-brand-500 focus:ring-brand-500" />
            <span class="text-xs text-zinc-500">Akceptuję <a href="/regulamin" class="text-brand-600 dark:text-brand-400 underline" target="_blank">Regulamin</a> i <a href="/polityka-prywatnosci" class="text-brand-600 dark:text-brand-400 underline" target="_blank">Politykę prywatności</a></span>
          </label>

          <div id="error-msg" class="hidden text-sm text-red-500 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl"></div>

          <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5">Załóż konto</button>
        </form>

        <p class="text-[10px] text-zinc-400 text-center mt-4">
          Strona chroniona przez reCAPTCHA Google —
          <a href="https://policies.google.com/privacy" class="underline" target="_blank" rel="noopener">Prywatność</a> ·
          <a href="https://policies.google.com/terms" class="underline" target="_blank" rel="noopener">Warunki</a>
        </p>
      </div>

      <p class="text-center text-sm text-zinc-500 mt-6">
        Masz już konto? <a href="/auth/login" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Zaloguj się</a>
      </p>
    </div>
  </div>

  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script define:vars={{ siteKey }}>window.__RECAPTCHA_SITE_KEY = siteKey;</script>
  <script is:inline>
    (function(){var s=document.createElement('script');s.src='https://www.google.com/recaptcha/api.js?render='+window.__RECAPTCHA_SITE_KEY;s.async=true;document.head.appendChild(s)})();
    // Hide reCAPTCHA badge
    var style=document.createElement('style');style.textContent='.grecaptcha-badge{visibility:hidden!important}';document.head.appendChild(style);

    function handleGoogleCredential(response){
      fetch('/api/auth/google',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({credential:response.credential})})
        .then(function(r){if(!r.ok)return r.json().then(function(d){throw new Error(d.error)});return r.json()})
        .then(function(){window.location.href='/dashboard'})
        .catch(function(e){document.getElementById('error-msg').textContent=e.message;document.getElementById('error-msg').classList.remove('hidden')});
    }
  </script>

  <script>
    // Eye toggles
    document.querySelectorAll('.eye-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = document.getElementById(btn.getAttribute('data-target')!) as HTMLInputElement;
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        btn.querySelector('.eye-open')!.classList.toggle('hidden', !isPassword);
        btn.querySelector('.eye-closed')!.classList.toggle('hidden', isPassword);
      });
    });

    // Password strength
    const pw = document.getElementById('password') as HTMLInputElement;
    const bar = document.getElementById('strength-bar')!;
    const segments = bar.querySelectorAll('.strength-segment');
    const checks = {
      length: document.querySelector('[data-check="length"]')!,
      lower: document.querySelector('[data-check="lower"]')!,
      upper: document.querySelector('[data-check="upper"]')!,
      digit: document.querySelector('[data-check="digit"]')!,
      special: document.querySelector('[data-check="special"]')!,
    };

    pw.addEventListener('input', () => {
      const v = pw.value;
      bar.classList.toggle('hidden', v.length === 0);

      const c = {
        length: v.length >= 8,
        lower: /[a-z]/.test(v),
        upper: /[A-Z]/.test(v),
        digit: /[0-9]/.test(v),
        special: /[^a-zA-Z0-9]/.test(v),
      };

      const passed = Object.values(c).filter(Boolean).length;
      const colors = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-lime-500', 'bg-green-500'];

      segments.forEach((seg, i) => {
        seg.className = `strength-segment h-1.5 flex-1 rounded-full transition-colors ${i < passed ? colors[passed - 1] : 'bg-zinc-200 dark:bg-zinc-700'}`;
      });

      Object.entries(c).forEach(([key, ok]) => {
        const el = checks[key as keyof typeof checks];
        el.className = ok ? 'text-green-500' : 'text-zinc-400';
        el.textContent = (ok ? '✓ ' : '✗ ') + el.textContent!.replace(/^[✓✗] /, '');
      });

      checkMatch();
    });

    // Password match
    const pwc = document.getElementById('passwordConfirm') as HTMLInputElement;
    const matchMsg = document.getElementById('match-msg')!;

    function checkMatch() {
      if (!pwc.value) { matchMsg.classList.add('hidden'); return; }
      matchMsg.classList.remove('hidden');
      if (pw.value === pwc.value) {
        matchMsg.textContent = '✓ Hasła się zgadzają';
        matchMsg.className = 'text-[11px] mt-1 text-green-500';
      } else {
        matchMsg.textContent = '✗ Hasła nie są identyczne';
        matchMsg.className = 'text-[11px] mt-1 text-red-500';
      }
    }
    pwc.addEventListener('input', checkMatch);

    // Submit
    const form = document.getElementById('register-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Rejestracja...';

      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = pw.value;
      const passwordConfirm = pwc.value;
      const acceptTerms = (document.getElementById('acceptTerms') as HTMLInputElement).checked;

      try {
        let recaptchaToken = '';
        if ((window as any).grecaptcha && (window as any).__RECAPTCHA_SITE_KEY) {
          recaptchaToken = await (window as any).grecaptcha.execute((window as any).__RECAPTCHA_SITE_KEY, { action: 'register' });
        }

        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, password, passwordConfirm, name: name || undefined, acceptTerms, recaptchaToken }),
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Błąd rejestracji');

        if (data.requiresVerification) {
          window.location.href = `/auth/verify?email=${encodeURIComponent(email)}`;
          return;
        }

        window.location.href = '/dashboard';
      } catch (err: any) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Załóż konto';
      }
    });
  </script>
</Base>