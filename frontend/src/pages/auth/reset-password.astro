---
import Base from '../../layouts/Base.astro';
import { ThemeToggle } from '../../components/ui/ThemeToggle';
---

<Base title="Nowe hasło — Matury Online" noindex={true}>
  <div class="fixed top-4 right-4 z-50"><ThemeToggle client:load /></div>
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-brand-500/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20">
            <span class="text-white font-display font-bold text-lg">M</span>
          </div>
          <span class="font-display font-bold text-xl">Matury Online</span>
        </a>
        <h1 class="font-display font-bold text-2xl mb-2">Ustaw nowe hasło</h1>
      </div>

      <!-- Loading state -->
      <div id="loading" class="glass-card p-8 text-center">
        <div class="w-8 h-8 border-3 border-brand-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-sm text-zinc-500">Weryfikacja linku...</p>
      </div>

      <!-- Invalid token -->
      <div id="invalid" class="glass-card p-8 text-center hidden">
        <div class="text-5xl mb-4">⏰</div>
        <h2 class="font-display font-bold text-lg mb-2">Link wygasł</h2>
        <p class="text-sm text-zinc-500 mb-6">Ten link do resetu hasła jest nieprawidłowy lub wygasł.</p>
        <a href="/auth/forgot-password" class="btn-primary">Wyślij nowy link</a>
      </div>

      <!-- Reset form -->
      <div id="reset-card" class="glass-card p-8 hidden">
        <form id="reset-form" class="space-y-4">
          <div>
            <label for="password" class="block text-sm font-medium mb-1.5">Nowe hasło</label>
            <div class="relative">
              <input type="password" id="password" required minlength="8" class="input pr-11" placeholder="Min. 8 znaków" />
              <button type="button" class="eye-toggle absolute right-3 top-1/2 -translate-y-1/2 p-1 text-zinc-400 hover:text-zinc-600" data-target="password">
                <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
              </button>
            </div>
            <div id="strength-bar" class="mt-2 space-y-1.5 hidden">
              <div class="flex gap-1">
                <div class="seg h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="seg h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="seg h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="seg h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
                <div class="seg h-1.5 flex-1 rounded-full bg-zinc-200 dark:bg-zinc-700 transition-colors"></div>
              </div>
              <div id="checks" class="flex flex-wrap gap-x-3 gap-y-0.5 text-[11px]">
                <span data-c="l" class="text-zinc-400">✗ 8+ znaków</span>
                <span data-c="a" class="text-zinc-400">✗ mała litera</span>
                <span data-c="A" class="text-zinc-400">✗ wielka litera</span>
                <span data-c="0" class="text-zinc-400">✗ cyfra</span>
                <span data-c="!" class="text-zinc-400">✗ znak specjalny</span>
              </div>
            </div>
          </div>

          <div>
            <label for="passwordConfirm" class="block text-sm font-medium mb-1.5">Powtórz hasło</label>
            <div class="relative">
              <input type="password" id="passwordConfirm" required class="input pr-11" placeholder="Powtórz hasło" />
              <button type="button" class="eye-toggle absolute right-3 top-1/2 -translate-y-1/2 p-1 text-zinc-400 hover:text-zinc-600" data-target="passwordConfirm">
                <svg class="eye-open w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <svg class="eye-closed w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
              </button>
            </div>
            <p id="match-msg" class="text-[11px] mt-1 hidden"></p>
          </div>

          <div id="error-msg" class="hidden text-sm text-red-500 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl"></div>

          <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5">Ustaw nowe hasło</button>
        </form>
      </div>

      <!-- Success -->
      <div id="success-card" class="glass-card p-8 text-center hidden">
        <div class="text-5xl mb-4">✅</div>
        <h2 class="font-display font-bold text-lg mb-2">Hasło zmienione!</h2>
        <p class="text-sm text-zinc-500 mb-6">Możesz się teraz zalogować nowym hasłem.</p>
        <a href="/auth/login" class="btn-primary">Zaloguj się</a>
      </div>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token') || '';

    const loadingEl = document.getElementById('loading')!;
    const invalidEl = document.getElementById('invalid')!;
    const resetCard = document.getElementById('reset-card')!;
    const successCard = document.getElementById('success-card')!;

    // Validate token
    (async () => {
      if (!token) { loadingEl.classList.add('hidden'); invalidEl.classList.remove('hidden'); return; }

      try {
        const res = await fetch(`/api/auth/reset-password/validate?token=${token}`);
        const data = await res.json();

        loadingEl.classList.add('hidden');
        if (data.valid) {
          resetCard.classList.remove('hidden');
        } else {
          invalidEl.classList.remove('hidden');
        }
      } catch {
        loadingEl.classList.add('hidden');
        invalidEl.classList.remove('hidden');
      }
    })();

    // Eye toggles
    document.querySelectorAll('.eye-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = document.getElementById(btn.getAttribute('data-target')!) as HTMLInputElement;
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        btn.querySelector('.eye-open')!.classList.toggle('hidden', !show);
        btn.querySelector('.eye-closed')!.classList.toggle('hidden', show);
      });
    });

    // Strength
    const pw = document.getElementById('password') as HTMLInputElement;
    const bar = document.getElementById('strength-bar')!;
    const segs = bar.querySelectorAll('.seg');
    const chk = { l: document.querySelector('[data-c="l"]')!, a: document.querySelector('[data-c="a"]')!, A: document.querySelector('[data-c="A"]')!, '0': document.querySelector('[data-c="0"]')!, '!': document.querySelector('[data-c="!"]')! };

    pw.addEventListener('input', () => {
      const v = pw.value;
      bar.classList.toggle('hidden', !v);
      const c = { l: v.length >= 8, a: /[a-z]/.test(v), A: /[A-Z]/.test(v), '0': /[0-9]/.test(v), '!': /[^a-zA-Z0-9]/.test(v) };
      const n = Object.values(c).filter(Boolean).length;
      const cols = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-lime-500', 'bg-green-500'];
      segs.forEach((s, i) => { s.className = `seg h-1.5 flex-1 rounded-full transition-colors ${i < n ? cols[n - 1] : 'bg-zinc-200 dark:bg-zinc-700'}`; });
      Object.entries(c).forEach(([k, ok]) => {
        const el = chk[k as keyof typeof chk];
        el.className = ok ? 'text-green-500' : 'text-zinc-400';
        el.textContent = (ok ? '✓ ' : '✗ ') + el.textContent!.replace(/^[✓✗] /, '');
      });
      checkMatch();
    });

    const pwc = document.getElementById('passwordConfirm') as HTMLInputElement;
    const matchMsg = document.getElementById('match-msg')!;
    function checkMatch() {
      if (!pwc.value) { matchMsg.classList.add('hidden'); return; }
      matchMsg.classList.remove('hidden');
      matchMsg.textContent = pw.value === pwc.value ? '✓ Hasła się zgadzają' : '✗ Hasła nie są identyczne';
      matchMsg.className = `text-[11px] mt-1 ${pw.value === pwc.value ? 'text-green-500' : 'text-red-500'}`;
    }
    pwc.addEventListener('input', checkMatch);

    // Submit
    const form = document.getElementById('reset-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Zapisywanie...';

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, password: pw.value, passwordConfirm: pwc.value }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);

        resetCard.classList.add('hidden');
        successCard.classList.remove('hidden');
      } catch (err: any) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Ustaw nowe hasło';
      }
    });
  </script>
</Base>