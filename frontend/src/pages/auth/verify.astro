---
import Base from '../../layouts/Base.astro';
import { ThemeToggle } from '../../components/ui/ThemeToggle';
---

<Base title="Weryfikacja email — Matury Online" noindex={true}>
  <div class="fixed top-4 right-4 z-50"><ThemeToggle client:load /></div>
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-brand-500/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20">
            <span class="text-white font-display font-bold text-lg">M</span>
          </div>
          <span class="font-display font-bold text-xl">Matury Online</span>
        </a>
        <div class="text-5xl mb-4">📧</div>
        <h1 class="font-display font-bold text-2xl mb-2">Sprawdź swoją skrzynkę</h1>
        <p class="text-zinc-500 text-sm">Wysłaliśmy 6-cyfrowy kod na adres:</p>
        <p id="email-display" class="font-semibold text-sm mt-1"></p>
      </div>

      <div class="glass-card p-8">
        <form id="verify-form">
          <div class="flex justify-center gap-3 mb-6" id="code-inputs">
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="0" autofocus />
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="1" />
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="2" />
            <div class="w-2 flex items-center"><div class="w-full h-0.5 bg-zinc-300 dark:bg-zinc-600 rounded"></div></div>
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="3" />
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="4" />
            <input type="text" inputmode="numeric" maxlength="1" class="code-digit w-12 h-14 text-center text-xl font-display font-bold rounded-xl border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-surface-800 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition-all" data-index="5" />
          </div>

          <div id="error-msg" class="hidden text-sm text-red-500 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl mb-4"></div>
          <div id="success-msg" class="hidden text-sm text-green-600 bg-green-50 dark:bg-green-900/20 p-3 rounded-xl mb-4"></div>

          <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5" disabled>
            Weryfikuj
          </button>
        </form>

        <div class="text-center mt-6">
          <p class="text-sm text-zinc-500 mb-2">Nie dostałeś kodu?</p>
          <button id="resend-btn" class="text-sm text-brand-600 dark:text-brand-400 font-semibold hover:underline disabled:opacity-50 disabled:cursor-not-allowed">
            Wyślij ponownie
          </button>
          <span id="resend-timer" class="text-xs text-zinc-400 ml-1 hidden"></span>
        </div>
      </div>

      <p class="text-center text-sm text-zinc-500 mt-6">
        <a href="/auth/register" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">← Wróć do rejestracji</a>
      </p>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const email = params.get('email') || '';

    if (!email) {
      window.location.href = '/auth/register';
    }

    document.getElementById('email-display')!.textContent = email;

    const digits = document.querySelectorAll('.code-digit') as NodeListOf<HTMLInputElement>;
    const form = document.getElementById('verify-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg')!;
    const successMsg = document.getElementById('success-msg')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const resendBtn = document.getElementById('resend-btn') as HTMLButtonElement;
    const resendTimer = document.getElementById('resend-timer')!;

    let submitting = false;

    function getCode(): string {
      return Array.from(digits).map(d => d.value).join('');
    }

    function checkFull() {
      const code = getCode();
      submitBtn.disabled = code.length < 6;
      // Auto-submit when all 6 digits filled
      if (code.length === 6 && !submitting) {
        submitCode(code);
      }
    }

    // Input handling
    digits.forEach((input, i) => {
      input.addEventListener('input', (e) => {
        const val = input.value.replace(/\D/g, '');
        input.value = val.slice(-1);

        if (val && i < 5) {
          digits[i + 1].focus();
        }
        checkFull();
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !input.value && i > 0) {
          digits[i - 1].focus();
          digits[i - 1].value = '';
        }
      });

      // Paste support
      input.addEventListener('paste', (e) => {
        e.preventDefault();
        const pasted = (e.clipboardData?.getData('text') || '').replace(/\D/g, '').slice(0, 6);
        pasted.split('').forEach((ch, idx) => {
          if (digits[idx]) digits[idx].value = ch;
        });
        if (pasted.length > 0) digits[Math.min(pasted.length, 5)].focus();
        checkFull();
      });
    });

    async function submitCode(code: string) {
      if (submitting) return;
      submitting = true;
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Weryfikacja...';

      try {
        const res = await fetch('/api/auth/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, code }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Błąd weryfikacji');

        successMsg.textContent = '✓ Email zweryfikowany! Przekierowuję...';
        successMsg.classList.remove('hidden');

        setTimeout(() => { window.location.href = '/dashboard'; }, 1000);
      } catch (err: any) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Weryfikuj';
        // Clear inputs on error
        digits.forEach(d => d.value = '');
        digits[0].focus();
      } finally {
        submitting = false;
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      submitCode(getCode());
    });

    // Resend with cooldown
    let cooldown = 0;
    function startCooldown(sec: number) {
      cooldown = sec;
      resendBtn.disabled = true;
      resendTimer.classList.remove('hidden');
      const tick = () => {
        if (cooldown <= 0) {
          resendBtn.disabled = false;
          resendTimer.classList.add('hidden');
          return;
        }
        resendTimer.textContent = `(${cooldown}s)`;
        cooldown--;
        setTimeout(tick, 1000);
      };
      tick();
    }

    // Start initial cooldown (code was just sent)
    startCooldown(60);

    resendBtn.addEventListener('click', async () => {
      resendBtn.disabled = true;
      errorMsg.classList.add('hidden');

      try {
        const res = await fetch('/api/auth/resend-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (res.status === 429) {
          const data = await res.json();
          throw new Error(data.error);
        }

        successMsg.textContent = 'Nowy kod wysłany!';
        successMsg.classList.remove('hidden');
        setTimeout(() => successMsg.classList.add('hidden'), 3000);
        startCooldown(60);
      } catch (err: any) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
        resendBtn.disabled = false;
      }
    });
  </script>
</Base>