---
import Base from '../../layouts/Base.astro';
import { ThemeToggle } from '../../components/ui/ThemeToggle';
const siteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
---

<Base title="Resetowanie hasła — Matury Online" noindex={true}>
<div id="auth-guard" class="fixed inset-0 bg-white dark:bg-surface-900 z-[9999]"></div>

<script is:inline>
  // Redirect logged-in users to dashboard
  (function() {
    fetch('/api/auth/me', { credentials: 'include' })
      .then(function(r) {
        if (r.ok) {
          window.location.replace('/dashboard');
        } else {
          document.getElementById('auth-guard')?.remove();
        }
      })
      .catch(function() {
        document.getElementById('auth-guard')?.remove();
      });
  })();
</script>

  <div class="fixed top-4 right-4 z-50"><ThemeToggle client:load /></div>
  <div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/3 left-1/3 w-[400px] h-[400px] bg-brand-500/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-navy-600 flex items-center justify-center shadow-lg shadow-brand-500/20">
            <span class="text-white font-display font-bold text-lg">M</span>
          </div>
          <span class="font-display font-bold text-xl">Matury Online</span>
        </a>
        <h1 class="font-display font-bold text-2xl mb-2">Resetowanie hasła</h1>
        <p class="text-zinc-500 text-sm">Podaj email, a wyślemy link do resetu hasła</p>
      </div>

      <div class="glass-card p-8">
        <form id="forgot-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium mb-1.5">Email</label>
            <input type="email" id="email" required class="input" placeholder="twoj@email.pl" />
          </div>

          <div id="error-msg" class="hidden text-sm text-red-500 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl"></div>
          <div id="success-msg" class="hidden text-sm text-green-600 bg-green-50 dark:bg-green-900/20 p-3 rounded-xl"></div>

          <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5">Wyślij link</button>
        </form>

        <p class="text-[10px] text-zinc-400 text-center mt-4">
          Strona chroniona przez reCAPTCHA Google —
          <a href="https://policies.google.com/privacy" class="underline" target="_blank" rel="noopener">Prywatność</a> ·
          <a href="https://policies.google.com/terms" class="underline" target="_blank" rel="noopener">Warunki</a>
        </p>
      </div>

      <p class="text-center text-sm text-zinc-500 mt-6">
        <a href="/auth/login" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">← Wróć do logowania</a>
      </p>
    </div>
  </div>

  <script define:vars={{ siteKey }}>window.__RECAPTCHA_SITE_KEY = siteKey;</script>
  <script is:inline>
    (function(){var s=document.createElement('script');s.src='https://www.google.com/recaptcha/api.js?render='+window.__RECAPTCHA_SITE_KEY;s.async=true;document.head.appendChild(s)})();
    var style=document.createElement('style');style.textContent='.grecaptcha-badge{visibility:hidden!important}';document.head.appendChild(style);
  </script>

  <script>
    const form = document.getElementById('forgot-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg')!;
    const successMsg = document.getElementById('success-msg')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      successMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wysyłanie...';

      const email = (document.getElementById('email') as HTMLInputElement).value;

      try {
        let recaptchaToken = '';
        if ((window as any).grecaptcha && (window as any).__RECAPTCHA_SITE_KEY) {
          recaptchaToken = await (window as any).grecaptcha.execute((window as any).__RECAPTCHA_SITE_KEY, { action: 'forgot_password' });
        }

        await fetch('/api/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, recaptchaToken }),
        });

        // Always show success (don't reveal if email exists)
        successMsg.innerHTML = '📧 Jeśli konto z tym emailem istnieje, wysłaliśmy link do resetu hasła. Sprawdź skrzynkę (również spam).';
        successMsg.classList.remove('hidden');
        submitBtn.textContent = 'Wysłano';
      } catch (err: any) {
        errorMsg.textContent = err.message;
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Wyślij link';
      }
    });
  </script>
</Base>